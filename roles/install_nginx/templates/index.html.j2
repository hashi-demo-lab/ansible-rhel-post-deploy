<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certificate Lifecycle Management — HashiCorp Vault + Red Hat Ansible</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ── Reset ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design Tokens ────────────────────────────────── */
    :root {
      --bg:          oklch(97.5% 0.005 55);
      --bg-alt:      oklch(95% 0.008 55);
      --bg-warm:     oklch(96% 0.015 80);
      --bg-cool:     oklch(96.5% 0.008 240);
      --bg-light:    oklch(98.5% 0.003 55);
      --text:        oklch(18% 0.01 55);
      --text-muted:  oklch(45% 0.01 55);
      --text-faint:  oklch(65% 0.008 55);
      --vault-gold:  #FFD814;
      --vault-dark:  #1A1A2E;
      --redhat-red:  #EE0000;
      --accent:      oklch(55% 0.15 270);
      --border:      oklch(88% 0.008 55);

      --step-0: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --step-1: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
      --step-2: clamp(1.75rem, 1.4rem + 1.75vw, 2.5rem);
      --step-3: clamp(2.5rem, 1.8rem + 3.5vw, 4rem);
      --step-4: clamp(3.5rem, 2.2rem + 6.5vw, 6.5rem);
      --step-hero: clamp(3rem, 2rem + 5vw, 5.5rem);

      --space-xs:  clamp(0.5rem, 0.4rem + 0.5vw, 0.75rem);
      --space-s:   clamp(0.75rem, 0.6rem + 0.75vw, 1.25rem);
      --space-m:   clamp(1.5rem, 1rem + 2.5vw, 3rem);
      --space-l:   clamp(3rem, 2rem + 5vw, 6rem);
      --space-xl:  clamp(5rem, 3rem + 10vw, 10rem);

      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      --measure: 65ch;
    }

    /* ── Base ──────────────────────────────────────────── */
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

    body {
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      font-size: var(--step-0);
      font-weight: 400;
      line-height: 1.65;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    h1, h2, h3, h4 {
      font-family: 'Outfit', system-ui, -apple-system, sans-serif;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    p { max-width: var(--measure); }

    .wrap {
      width: min(90%, 72rem);
      margin-inline: auto;
      padding-inline: var(--space-s);
    }

    /* ── Chapter Side Navigation ──────────────────────── */
    .chapter-nav {
      position: fixed;
      right: clamp(1rem, 2vw, 2.5rem);
      top: 50%;
      transform: translateY(-50%);
      z-index: 100;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      align-items: flex-end;
    }

    .chapter-nav a {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--text-faint);
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      transition: color 0.3s var(--ease-out-expo);
    }

    .chapter-nav a .chapter-label {
      opacity: 0;
      transform: translateX(0.5rem);
      transition: opacity 0.25s ease, transform 0.25s var(--ease-out-expo);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      white-space: nowrap;
    }

    .chapter-nav a:hover .chapter-label {
      opacity: 1;
      transform: translateX(0);
    }

    .chapter-nav a .chapter-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--border);
      transition: background 0.3s ease, transform 0.3s var(--ease-out-expo);
      flex-shrink: 0;
    }

    .chapter-nav a.active {
      color: var(--text);
    }

    .chapter-nav a.active .chapter-dot {
      background: var(--vault-gold);
      transform: scale(1.5);
    }

    @media (max-width: 900px) {
      .chapter-nav { display: none; }
    }

    /* ── Scroll Reveals ───────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(2rem);
      transition: opacity 0.7s var(--ease-out-expo),
                  transform 0.7s var(--ease-out-expo);
      transition-delay: calc(var(--i, 0) * 80ms);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-slide-left {
      opacity: 0;
      transform: translateX(-3rem);
      transition: opacity 0.7s var(--ease-out-expo),
                  transform 0.7s var(--ease-out-expo);
      transition-delay: calc(var(--i, 0) * 80ms);
    }

    .reveal-slide-left.visible {
      opacity: 1;
      transform: translateX(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal, .reveal-slide-left {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .hero-word { opacity: 1 !important; transform: none !important; }
      .hero-line-draw { transform: scaleX(1) !important; }
      .logo-float { animation: none !important; }
      .stat-mega { opacity: 1 !important; transform: none !important; }
      .bridge-line { stroke-dashoffset: 0 !important; }
      .svg-underline path { stroke-dashoffset: 0 !important; }
      .lock-icon { transform: none !important; }
      .typewriter-char { opacity: 1 !important; }
    }

    /* ── Section Backgrounds (color transitions) ──────── */
    .section-hero {
      background: linear-gradient(180deg, var(--bg) 0%, var(--bg-warm) 100%);
    }

    .section-problem {
      background: linear-gradient(180deg, var(--bg-warm) 0%, var(--bg-alt) 100%);
    }

    .section-together {
      background: linear-gradient(180deg, var(--bg-alt) 0%, var(--bg-warm) 100%);
    }

    .section-capabilities {
      background: linear-gradient(180deg, var(--bg-warm) 0%, var(--bg-cool) 50%, var(--bg-alt) 100%);
    }

    .section-outcomes {
      background: linear-gradient(180deg, var(--bg-alt) 0%, var(--bg-light) 100%);
    }

    /* ── Chapter Watermarks ───────────────────────────── */
    .chapter-watermark {
      position: absolute;
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(8rem, 15vw, 22rem);
      font-weight: 800;
      color: var(--text-faint);
      opacity: 0.06;
      pointer-events: none;
      line-height: 1;
      user-select: none;
      z-index: 0;
      will-change: transform;
    }

    /* ── HERO ─────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-block: var(--space-xl);
      overflow: hidden;
    }

    .hero .chapter-watermark {
      top: 10%;
      right: -5%;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      gap: var(--space-m);
    }

    .hero-logos {
      display: flex;
      align-items: center;
      gap: var(--space-m);
    }

    .hero-logos .logo-hashi {
      width: clamp(3rem, 2.5rem + 2.5vw, 4.5rem);
      color: var(--vault-gold);
      will-change: transform;
    }

    .hero-logos .logo-redhat {
      width: clamp(4.5rem, 3.5rem + 4vw, 7rem);
      will-change: transform;
    }

    .hero-logos .logo-separator {
      width: 1px;
      height: 2.5rem;
      background: var(--border);
    }

    .logo-float {
      animation: logoFloat 6s ease-in-out infinite;
    }

    .logo-float-delay {
      animation: logoFloat 6s ease-in-out infinite;
      animation-delay: -3s;
    }

    @keyframes logoFloat {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    /* Hero headline — word-by-word reveal */
    .hero h1 {
      font-size: var(--step-hero);
      font-weight: 800;
      max-width: 18ch;
      overflow: hidden;
    }

    .hero-word {
      display: inline-block;
      opacity: 0;
      transform: translateY(100%);
      transition: opacity 0.6s var(--ease-out-expo),
                  transform 0.6s var(--ease-out-expo);
    }

    .hero-word.word-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-sub {
      font-size: var(--step-1);
      color: var(--text-muted);
      font-weight: 400;
      max-width: 48ch;
      line-height: 1.45;
    }

    /* Animated line divider */
    .hero-line-draw {
      width: clamp(4rem, 3rem + 8vw, 12rem);
      height: 3px;
      background: var(--vault-gold);
      border: none;
      margin-top: var(--space-s);
      transform-origin: left;
      transform: scaleX(0);
      transition: transform 1.2s var(--ease-out-expo);
      transition-delay: 1.4s;
    }

    .hero-line-draw.line-visible {
      transform: scaleX(1);
    }

    /* ── PROBLEM ──────────────────────────────────────── */
    .problem {
      position: relative;
      padding-block: var(--space-xl);
      overflow: hidden;
    }

    .problem .chapter-watermark {
      top: -5%;
      left: -3%;
    }

    .section-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: var(--space-l);
      position: relative;
      z-index: 1;
    }

    .stat-list {
      display: grid;
      gap: var(--space-l);
      position: relative;
      z-index: 1;
    }

    .stat-item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-s) var(--space-m);
      align-items: baseline;
      position: relative;
    }

    /* The mega stat — 40% layered behind text */
    .stat-mega-wrap {
      position: relative;
    }

    .stat-mega {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(6rem, 15vw, 18rem);
      font-weight: 800;
      line-height: 0.85;
      color: var(--text);
      opacity: 0.08;
      position: absolute;
      top: -0.2em;
      left: -0.05em;
      z-index: 0;
      pointer-events: none;
      will-change: transform;
    }

    .stat-mega.counter-visible {
      animation: megaFadeIn 1s var(--ease-out-expo) forwards;
    }

    @keyframes megaFadeIn {
      from { opacity: 0; transform: translateY(2rem) scale(0.95); }
      to { opacity: 0.08; transform: translateY(0) scale(1); }
    }

    .stat-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-4);
      font-weight: 800;
      line-height: 1;
      color: var(--text);
      position: relative;
      z-index: 1;
    }

    .stat-body {
      padding-top: 0.35em;
      position: relative;
      z-index: 1;
    }

    .stat-desc {
      font-size: var(--step-1);
      font-weight: 500;
      color: var(--text);
      margin-bottom: var(--space-xs);
    }

    .stat-source {
      font-size: var(--step-0);
      color: var(--text-muted);
      font-weight: 400;
    }

    @media (max-width: 640px) {
      .stat-item { grid-template-columns: 1fr; gap: var(--space-xs); }
      .stat-mega { font-size: clamp(5rem, 30vw, 10rem); }
    }

    /* ── SVG Underlines ───────────────────────────────── */
    .svg-underline {
      position: relative;
      display: inline;
      white-space: nowrap;
    }

    .svg-underline svg {
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 100%;
      height: 8px;
      overflow: visible;
    }

    .svg-underline path {
      fill: none;
      stroke: var(--vault-gold);
      stroke-width: 3;
      stroke-linecap: round;
      stroke-dasharray: 300;
      stroke-dashoffset: 300;
      transition: stroke-dashoffset 0.8s var(--ease-out-expo);
    }

    .svg-underline.underline-visible path {
      stroke-dashoffset: 0;
    }

    /* ── BETTER TOGETHER ──────────────────────────────── */
    .together {
      position: relative;
      padding-block: var(--space-xl);
      overflow: hidden;
    }

    .together .chapter-watermark {
      top: 5%;
      right: -5%;
    }

    .together-heading {
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-l);
      max-width: 22ch;
    }

    .together-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-l);
      position: relative;
    }

    @media (min-width: 768px) {
      .together-grid {
        grid-template-columns: 1fr 80px 1fr;
        gap: var(--space-m);
        align-items: start;
      }
    }

    /* SVG bridge connector */
    .bridge-container {
      display: none;
      align-items: center;
      justify-content: center;
      padding-top: 4rem;
    }

    @media (min-width: 768px) {
      .bridge-container { display: flex; }
    }

    .bridge-svg {
      width: 80px;
      height: 200px;
    }

    .bridge-line {
      fill: none;
      stroke: var(--vault-gold);
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-dasharray: 250;
      stroke-dashoffset: 250;
      transition: stroke-dashoffset 1.2s var(--ease-out-expo);
    }

    .bridge-line.bridge-drawn {
      stroke-dashoffset: 0;
    }

    .bridge-pulse {
      fill: none;
      stroke: var(--vault-gold);
      stroke-width: 2.5;
      stroke-linecap: round;
      opacity: 0;
    }

    .bridge-pulse.bridge-pulse-active {
      animation: bridgePulse 2s ease-in-out infinite;
      animation-delay: 1.3s;
    }

    @keyframes bridgePulse {
      0%, 100% { opacity: 0; stroke-width: 2.5; }
      50% { opacity: 0.4; stroke-width: 5; }
    }

    .engine-section .engine-logo {
      margin-bottom: var(--space-s);
    }

    .engine-section .logo-hashi {
      width: 2.25rem;
      color: var(--vault-gold);
    }

    .engine-section .logo-redhat {
      width: 3.5rem;
    }

    .engine-title {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .engine-subtitle {
      font-size: var(--step-0);
      color: var(--text-muted);
      font-weight: 500;
      margin-bottom: var(--space-m);
    }

    .engine-list {
      list-style: none;
      display: grid;
      gap: var(--space-s);
    }

    .engine-list li {
      position: relative;
      padding-left: 1.4em;
      line-height: 1.55;
      opacity: 0;
      transform: translateY(1rem);
      transition: opacity 0.5s var(--ease-out-expo),
                  transform 0.5s var(--ease-out-expo);
      transition-delay: calc(var(--i, 0) * 100ms);
    }

    .engine-list li.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .engine-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .vault-col .engine-list li::before { background: var(--vault-gold); }
    .aap-col .engine-list li::before { background: var(--redhat-red); }

    /* Card tilt hover effect */
    .tilt-card {
      transition: transform 0.3s var(--ease-out-expo);
      transform-style: preserve-3d;
      perspective: 1000px;
    }

    .tilt-card:hover {
      transform: perspective(1000px) rotateX(1deg) rotateY(-1deg);
    }

    /* ── CAPABILITIES — Horizontal Scroll Gallery ─────── */
    .capabilities {
      position: relative;
      padding-block: var(--space-xl);
      overflow: hidden;
    }

    .capabilities .chapter-watermark {
      top: 0;
      left: -3%;
    }

    .cap-header {
      position: relative;
      z-index: 1;
    }

    .capabilities-heading {
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-l);
      max-width: 22ch;
    }

    .cap-scroll-container {
      position: relative;
      z-index: 1;
    }

    .cap-track {
      display: flex;
      gap: var(--space-m);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: var(--space-m);
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }

    .cap-track::-webkit-scrollbar { height: 4px; }
    .cap-track::-webkit-scrollbar-track { background: transparent; }
    .cap-track::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .cap-card {
      flex: 0 0 clamp(280px, 75vw, 420px);
      scroll-snap-align: start;
      padding: var(--space-m);
      position: relative;
    }

    .cap-card-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(4rem, 8vw, 7rem);
      font-weight: 800;
      line-height: 1;
      color: var(--vault-gold);
      opacity: 0.2;
      margin-bottom: var(--space-xs);
      transition: opacity 0.4s ease;
    }

    .cap-card:hover .cap-card-number {
      opacity: 0.5;
    }

    .cap-card-name {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .cap-card-desc {
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 38ch;
    }

    .cap-scroll-hint {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-faint);
      font-size: 0.8125rem;
      margin-top: var(--space-s);
      font-family: 'Outfit', system-ui, sans-serif;
      letter-spacing: 0.05em;
    }

    .cap-scroll-hint svg {
      width: 1.25rem;
      height: 1.25rem;
      animation: scrollHintBounce 1.5s ease-in-out infinite;
    }

    @keyframes scrollHintBounce {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(6px); }
    }

    /* ── OUTCOMES ──────────────────────────────────────── */
    .outcomes {
      position: relative;
      padding-block: var(--space-xl);
      overflow: hidden;
    }

    .outcomes .chapter-watermark {
      bottom: -5%;
      right: -5%;
    }

    .outcomes-heading {
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-l);
      max-width: 24ch;
    }

    .outcomes-list {
      display: grid;
      gap: var(--space-l);
    }

    @media (min-width: 768px) {
      .outcomes-list {
        grid-template-columns: 1fr 1fr;
        gap: var(--space-l) var(--space-xl);
      }
    }

    .outcome-item {
      position: relative;
    }

    .outcome-big {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: var(--space-xs);
    }

    .outcome-big .accent-gold { color: oklch(55% 0.15 85); }
    .outcome-big .accent-red  { color: var(--redhat-red); }

    .outcome-text {
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ── FOOTER ────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding-block: var(--space-m);
      background: var(--bg-light);
    }

    .footer-inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-s) var(--space-m);
    }

    .footer-left {
      display: flex;
      align-items: center;
      gap: var(--space-s);
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .footer-left .logo-hashi {
      width: 1.5rem;
      color: var(--vault-gold);
    }

    .footer-left .logo-redhat {
      width: 2.5rem;
    }

    .footer-right {
      font-size: 0.8125rem;
      color: var(--text-muted);
    }

    .footer-host {
      font-family: 'DM Sans', monospace;
      font-weight: 500;
    }

    .typewriter-char {
      opacity: 0;
      transition: opacity 0.05s ease;
    }

    .typewriter-char.char-visible {
      opacity: 1;
    }

    /* Lock icon animation */
    .lock-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .lock-icon {
      display: inline-block;
      width: 1em;
      height: 1em;
      position: relative;
    }

    .lock-icon svg {
      width: 100%;
      height: 100%;
    }

    .lock-shackle {
      transform-origin: center bottom;
      transform: rotate(15deg);
      transition: transform 0.4s var(--ease-out-expo);
    }

    .lock-icon.lock-closed .lock-shackle {
      transform: rotate(0deg);
    }

    /* ── Parallax layer ───────────────────────────────── */
    .parallax-layer {
      will-change: transform;
      transition: transform 0.1s linear;
    }
  </style>
</head>
<body>

  <!-- ═══════════════ Chapter Side Navigation ═══════════════ -->
  <nav class="chapter-nav" aria-label="Page sections">
    <a href="#hero" class="active" data-chapter="hero">
      <span class="chapter-label">Intro</span>
      <span class="chapter-dot"></span>
    </a>
    <a href="#problem" data-chapter="problem">
      <span class="chapter-label">The Problem</span>
      <span class="chapter-dot"></span>
    </a>
