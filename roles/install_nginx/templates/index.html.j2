<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HashiCorp Vault + Red Hat AAP — Better Together</title>
<style>
/* ============================================================
   COLOR SYSTEM & CUSTOM PROPERTIES
   ============================================================ */
:root {
  --bg-base: #0A0A0B;
  --bg-surface: #111118;
  --bg-card: #1A1A2E;
  --bg-card-hover: #222240;
  --vault-gold: #FFD814;
  --vault-gold-dim: rgba(255,216,20,0.15);
  --vault-gold-glow: rgba(255,216,20,0.35);
  --rh-red: #EE0000;
  --rh-red-dim: rgba(238,0,0,0.15);
  --rh-red-glow: rgba(238,0,0,0.35);
  --purple: #8A3FFC;
  --purple-dim: rgba(138,63,252,0.12);
  --purple-glow: rgba(138,63,252,0.3);
  --text-primary: #F0F0F5;
  --text-secondary: #9D9DB5;
  --text-muted: #6B6B80;
  --border-subtle: rgba(255,255,255,0.06);
  --border-glow: rgba(138,63,252,0.25);
  --gradient-hero: linear-gradient(135deg, #0A0A0B 0%, #1A1A2E 40%, #160a2e 70%, #0A0A0B 100%);
  --gradient-gold-red: linear-gradient(135deg, var(--vault-gold), var(--rh-red));
  --gradient-purple: linear-gradient(135deg, var(--purple), #c471f5);
  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ============================================================
   FONT LOADING (graceful fallback for air-gapped)
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
body {
  font-family: var(--font-sans);
  background: var(--bg-base);
  color: var(--text-primary);
  line-height: 1.7;
  overflow-x: hidden;
}
a { color: inherit; text-decoration: none; }
img, svg { display: block; max-width: 100%; }

/* ============================================================
   SCROLLBAR
   ============================================================ */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--bg-base); }
::-webkit-scrollbar-thumb { background: var(--bg-card); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--purple); }

/* ============================================================
   UTILITY & LAYOUT
   ============================================================ */
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.section { padding: 120px 0; position: relative; }
.section-label {
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--purple);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.section-label::before {
  content: '';
  width: 24px;
  height: 2px;
  background: var(--purple);
  border-radius: 1px;
}
.section-title {
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 24px;
}
.section-subtitle {
  font-size: 18px;
  color: var(--text-secondary);
  max-width: 640px;
  line-height: 1.8;
}

/* ============================================================
   SCROLL REVEAL SYSTEM
   ============================================================ */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }
.reveal-delay-5 { transition-delay: 0.5s; }

/* ============================================================
   NAVIGATION
   ============================================================ */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 20px 0;
  transition: all 0.4s var(--ease-out-expo);
  background: transparent;
}
.nav.scrolled {
  padding: 12px 0;
  background: rgba(10,10,11,0.85);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--border-subtle);
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}
.nav-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  font-weight: 700;
  font-size: 15px;
  letter-spacing: -0.01em;
}
.nav-brand svg { flex-shrink: 0; }
.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
}
.nav-links a {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  transition: color 0.3s;
  position: relative;
}
.nav-links a:hover { color: var(--text-primary); }
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--gradient-gold-red);
  border-radius: 1px;
  transition: width 0.3s var(--ease-out-expo);
}
.nav-links a:hover::after { width: 100%; }

@media (max-width: 768px) {
  .nav-links { display: none; }
}

/* ============================================================
   HERO SECTION
   ============================================================ */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: var(--gradient-hero);
}

/* Animated gradient overlay */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 800px 600px at 20% 50%, rgba(138,63,252,0.08), transparent),
    radial-gradient(ellipse 600px 500px at 80% 30%, rgba(238,0,0,0.06), transparent),
    radial-gradient(ellipse 700px 500px at 50% 80%, rgba(255,216,20,0.04), transparent);
  animation: heroGradientShift 12s ease-in-out infinite alternate;
}

@keyframes heroGradientShift {
  0% { opacity: 1; transform: scale(1) translate(0, 0); }
  50% { opacity: 0.8; transform: scale(1.1) translate(-2%, 3%); }
  100% { opacity: 1; transform: scale(1.05) translate(2%, -2%); }
}

/* Grid pattern overlay */
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 70%);
}

/* Floating particles */
.particles {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}
.particle {
  position: absolute;
  border-radius: 50%;
  animation: particleFloat linear infinite;
  opacity: 0;
}
.particle:nth-child(1) { width: 4px; height: 4px; background: var(--vault-gold); left: 10%; animation-duration: 18s; animation-delay: 0s; }
.particle:nth-child(2) { width: 3px; height: 3px; background: var(--rh-red); left: 20%; animation-duration: 22s; animation-delay: 2s; }
.particle:nth-child(3) { width: 5px; height: 5px; background: var(--purple); left: 35%; animation-duration: 16s; animation-delay: 4s; }
.particle:nth-child(4) { width: 3px; height: 3px; background: var(--vault-gold); left: 50%; animation-duration: 20s; animation-delay: 1s; }
.particle:nth-child(5) { width: 4px; height: 4px; background: var(--rh-red); left: 65%; animation-duration: 24s; animation-delay: 3s; }
.particle:nth-child(6) { width: 3px; height: 3px; background: var(--purple); left: 75%; animation-duration: 17s; animation-delay: 5s; }
.particle:nth-child(7) { width: 5px; height: 5px; background: var(--vault-gold); left: 88%; animation-duration: 21s; animation-delay: 2.5s; }
.particle:nth-child(8) { width: 4px; height: 4px; background: var(--rh-red); left: 5%; animation-duration: 19s; animation-delay: 6s; }
.particle:nth-child(9) { width: 3px; height: 3px; background: var(--purple); left: 42%; animation-duration: 23s; animation-delay: 1.5s; }
.particle:nth-child(10) { width: 4px; height: 4px; background: var(--vault-gold); left: 58%; animation-duration: 15s; animation-delay: 4.5s; }
.particle:nth-child(11) { width: 3px; height: 3px; background: var(--rh-red); left: 92%; animation-duration: 20s; animation-delay: 3.5s; }
.particle:nth-child(12) { width: 5px; height: 5px; background: var(--purple); left: 28%; animation-duration: 18s; animation-delay: 0.5s; }

@keyframes particleFloat {
  0% { transform: translateY(110vh) scale(0); opacity: 0; }
  10% { opacity: 0.6; transform: translateY(90vh) scale(1); }
  90% { opacity: 0.6; }
  100% { transform: translateY(-10vh) scale(0.5); opacity: 0; }
}

/* Orbital rings */
.orbital-ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid transparent;
  pointer-events: none;
}
.orbital-ring-1 {
  width: 600px; height: 600px;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-color: rgba(138,63,252,0.08);
  animation: orbitSpin 40s linear infinite;
}
.orbital-ring-2 {
  width: 800px; height: 800px;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-color: rgba(255,216,20,0.05);
  animation: orbitSpin 55s linear infinite reverse;
}
.orbital-ring-3 {
  width: 1000px; height: 1000px;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-color: rgba(238,0,0,0.04);
  animation: orbitSpin 70s linear infinite;
}

/* Orbital dots */
.orbital-ring::after {
  content: '';
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}
.orbital-ring-1::after { background: var(--purple); box-shadow: 0 0 12px var(--purple-glow); }
.orbital-ring-2::after { background: var(--vault-gold); box-shadow: 0 0 12px var(--vault-gold-glow); }
.orbital-ring-3::after { background: var(--rh-red); box-shadow: 0 0 12px var(--rh-red-glow); }

@keyframes orbitSpin {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 900px;
  padding: 0 24px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  border-radius: 100px;
  background: rgba(138,63,252,0.1);
  border: 1px solid rgba(138,63,252,0.2);
  font-size: 13px;
  font-weight: 600;
  color: #c4a0ff;
  letter-spacing: 0.5px;
  margin-bottom: 32px;
  animation: badgePulse 3s ease-in-out infinite;
}
.hero-badge .dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #00e676;
  box-shadow: 0 0 8px rgba(0,230,118,0.5);
  animation: dotPulse 2s ease-in-out infinite;
}

@keyframes badgePulse {
  0%, 100% { border-color: rgba(138,63,252,0.2); }
  50% { border-color: rgba(138,63,252,0.4); }
}
@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.hero-logos {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32px;
  margin-bottom: 40px;
  animation: heroFadeIn 1s var(--ease-out-expo) 0.2s both;
}
.hero-logo-vault, .hero-logo-aap {
  width: 72px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-logo-plus {
  font-size: 28px;
  font-weight: 300;
  color: var(--text-muted);
  animation: plusPulse 3s ease-in-out infinite;
}
@keyframes plusPulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.15); }
}

.hero h1 {
  font-size: clamp(40px, 6.5vw, 76px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: 24px;
  animation: heroFadeIn 1s var(--ease-out-expo) 0.4s both;
}
.hero h1 .gradient-text {
  background: var(--gradient-gold-red);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-description {
  font-size: clamp(17px, 2vw, 20px);
  color: var(--text-secondary);
  max-width: 600px;
  margin: 0 auto 40px;
  line-height: 1.7;
  animation: heroFadeIn 1s var(--ease-out-expo) 0.6s both;
}

.hero-cta-group {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  animation: heroFadeIn 1s var(--ease-out-expo) 0.8s both;
}

@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s var(--ease-out-expo);
  border: none;
  position: relative;
  overflow: hidden;
}
.btn-primary {
  background: var(--gradient-gold-red);
  color: #0A0A0B;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(255,216,20,0.25); }
.btn-secondary {
  background: transparent;
  color: var(--text-primary);
  border: 1px solid rgba(255,255,255,0.12);
}
.btn-secondary:hover {
  border-color: var(--purple);
  background: var(--purple-dim);
  transform: translateY(-2px);
}

/* Scroll indicator */
.scroll-indicator {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  animation: scrollBounce 2.5s ease-in-out infinite;
}
.scroll-indicator span {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
}
.scroll-mouse {
  width: 24px;
  height: 38px;
  border: 2px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  position: relative;
}
.scroll-mouse::after {
  content: '';
  width: 3px;
  height: 8px;
  background: var(--purple);
  border-radius: 2px;
  position: absolute;
  top: 6px;
  left: 50%;
  transform: translateX(-50%);
  animation: scrollDot 2s ease-in-out infinite;
}
@keyframes scrollBounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}
@keyframes scrollDot {
  0% { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(14px); }
}

/* ============================================================
   PROBLEM SECTION
   ============================================================ */
.problem { background: var(--bg-base); }
.problem-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  margin-top: 60px;
}
.problem-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 20px;
  padding: 40px 32px;
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease-out-expo);
}
.problem-card:hover {
  border-color: var(--border-glow);
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}
.problem-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--gradient-gold-red);
  opacity: 0;
  transition: opacity 0.4s;
}
.problem-card:hover::before { opacity: 1; }
.problem-icon {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
}
.problem-icon.red { background: var(--rh-red-dim); }
.problem-icon.gold { background: var(--vault-gold-dim); }
.problem-icon.purple { background: var(--purple-dim); }
.problem-stat {
  font-size: clamp(40px, 5vw, 56px);
  font-weight: 900;
  line-height: 1;
  margin-bottom: 12px;
  letter-spacing: -0.03em;
}
.problem-stat.red { color: var(--rh-red); }
.problem-stat.gold { color: var(--vault-gold); }
.problem-stat.purple { color: var(--purple); }
.problem-card h3 {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 12px;
  letter-spacing: -0.01em;
}
.problem-card p {
  color: var(--text-secondary);
  font-size: 16px;
  line-height: 1.7;
}

/* ============================================================
   SOLUTION SECTION — THE BRIDGE
   ============================================================ */
.solution {
  background: var(--bg-surface);
  position: relative;
}
.solution::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-glow), transparent);
}

.solution-bridge {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 0;
  align-items: stretch;
  margin-top: 60px;
}
@media (max-width: 900px) {
  .solution-bridge {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .bridge-connector { display: none !important; }
}

.solution-pillar {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 24px;
  padding: 48px 36px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease-out-expo);
}
.solution-pillar:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}

.pillar-vault { border-color: rgba(255,216,20,0.1); }
.pillar-vault:hover { border-color: rgba(255,216,20,0.3); box-shadow: 0 20px 60px rgba(255,216,20,0.05); }
.pillar-aap { border-color: rgba(238,0,0,0.1); }
.pillar-aap:hover { border-color: rgba(238,0,0,0.3); box-shadow: 0 20px 60px rgba(238,0,0,0.05); }

.pillar-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 24px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pillar-vault .pillar-icon { background: var(--vault-gold-dim); }
.pillar-aap .pillar-icon { background: var(--rh-red-dim); }

.pillar-subtitle {
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.pillar-vault .pillar-subtitle { color: var(--vault-gold); }
.pillar-aap .pillar-subtitle { color: var(--rh-red); }

.solution-pillar h3 {
  font-size: 28px;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-bottom: 16px;
}
.solution-pillar p {
  color: var(--text-secondary);
  font-size: 16px;
  line-height: 1.7;
  margin-bottom: 24px;
}
.pillar-features {
  list-style: none;
  text-align: left;
}
.pillar-features li {
  padding: 10px 0;
  font-size: 15px;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid var(--border-subtle);
}
.pillar-features li:last-child { border-bottom: none; }
.pillar-features .check {
  width: 20px;
  height: 20px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.pillar-vault .check { background: var(--vault-gold-dim); color: var(--vault-gold); }
.pillar-aap .check { background: var(--rh-red-dim); color: var(--rh-red); }

/* Bridge connector */
.bridge-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 24px;
  position: relative;
}
.bridge-line {
  width: 2px;
  flex: 1;
  background: linear-gradient(180deg, var(--vault-gold-dim), var(--purple), var(--rh-red-dim));
  border-radius: 1px;
  position: relative;
  overflow: hidden;
}
.bridge-line::after {
  content: '';
  position: absolute;
  width: 100%;
  height: 40px;
  background: linear-gradient(180deg, transparent, var(--purple), transparent);
  animation: bridgePulse 2.5s ease-in-out infinite;
  top: 0;
}
@keyframes bridgePulse {
  0% { top: -40px; }
  100% { top: calc(100% + 40px); }
}
.bridge-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2px solid var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16px 0;
  box-shadow: 0 0 30px var(--purple-glow);
  animation: bridgeGlow 3s ease-in-out infinite;
  position: relative;
  z-index: 2;
}
@keyframes bridgeGlow {
  0%, 100% { box-shadow: 0 0 20px var(--purple-glow); }
  50% { box-shadow: 0 0 40px var(--purple-glow), 0 0 60px rgba(138,63,252,0.15); }
}

/* ============================================================
   LIFECYCLE WHEEL SECTION
   ============================================================ */
.lifecycle { background: var(--bg-base); position: relative; }
.lifecycle::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-glow), transparent);
}

.lifecycle-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  margin-top: 60px;
}
@media (max-width: 900px) {
  .lifecycle-layout {
    grid-template-columns: 1fr;
    gap: 48px;
  }
}

/* The circular diagram */
.wheel-container {
  position: relative;
  width: 100%;
  max-width: 450px;
  margin: 0 auto;
  aspect-ratio: 1;
}

.wheel-ring {
  position: absolute;
  inset: 10%;
  border-radius: 50%;
  border: 2px solid var(--border-subtle);
}
.wheel-ring-inner {
  position: absolute;
  inset: 30%;
  border-radius: 50%;
  border: 1px dashed rgba(138,63,252,0.15);
  animation: orbitSpin 30s linear infinite;
}

.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--purple-dim), var(--bg-card));
  border: 2px solid rgba(138,63,252,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40px var(--purple-glow);
  z-index: 2;
}
.wheel-center-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--purple);
  text-align: center;
  line-height: 1.3;
}

/* Wheel nodes positioned in a circle */
.wheel-node {
  position: absolute;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2px solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.4s var(--ease-out-expo);
  cursor: default;
  z-index: 3;
}
.wheel-node:hover {
  transform: scale(1.15);
  border-color: var(--purple);
  box-shadow: 0 0 30px var(--purple-glow);
}
.wheel-node svg { margin-bottom: 2px; }
.wheel-node-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--text-secondary);
}

/* Position 5 nodes in a circle — top, top-right, bottom-right, bottom-left, top-left */
.wheel-node:nth-child(1) { top: 0%; left: 50%; transform: translate(-50%, -50%); }
.wheel-node:nth-child(2) { top: 25%; right: 0%; transform: translate(50%, -50%); }
.wheel-node:nth-child(3) { bottom: 10%; right: 5%; transform: translate(50%, 50%); }
.wheel-node:nth-child(4) { bottom: 10%; left: 5%; transform: translate(-50%, 50%); }
.wheel-node:nth-child(5) { top: 25%; left: 0%; transform: translate(-50%, -50%); }

.wheel-node:nth-child(1):hover { transform: translate(-50%, -50%) scale(1.15); }
.wheel-node:nth-child(2):hover { transform: translate(50%, -50%) scale(1.15); }
.wheel-node:nth-child(3):hover { transform: translate(50%, 50%) scale(1.15); }
.wheel-node:nth-child(4):hover { transform: translate(-50%, 50%) scale(1.15); }
.wheel-node:nth-child(5):hover { transform: translate(-50%, -50%) scale(1.15); }

/* Connecting lines from center (decorative) */
.wheel-line {
  position: absolute;
  top: 50%;
  left: 50%;
  height: 2px;
  background: linear-gradient(90deg, var(--purple-glow), transparent);
  transform-origin: left center;
  z-index: 1;
  width: 35%;
}
.wheel-line:nth-child(6) { transform: rotate(-90deg); }
.wheel-line:nth-child(7) { transform: rotate(-18deg); }
.wheel-line:nth-child(8) { transform: rotate(54deg); }
.wheel-line:nth-child(9) { transform: rotate(126deg); }
.wheel-line:nth-child(10) { transform: rotate(198deg); }

/* Capability descriptions */
.capability-list { list-style: none; }
.capability-item {
  padding: 20px 24px;
  border-radius: 16px;
  border: 1px solid var(--border-subtle);
  margin-bottom: 12px;
  transition: all 0.3s var(--ease-out-expo);
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.capability-item:hover {
  background: var(--bg-card);
  border-color: var(--border-glow);
  transform: translateX(8px);
}
.capability-number {
  font-family: var(--font-mono);
  font-size: 14px;
  font-weight: 700;
  color: var(--purple);
  background: var(--purple-dim);
  width: 32px;
  height: 32px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.capability-item h4 {
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}
.capability-item p {
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ============================================================
   OUTCOMES SECTION
   ============================================================ */
.outcomes {
  background: var(--bg-surface);
  position: relative;
}
.outcomes::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-glow), transparent);
}
.outcomes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
  margin-top: 60px;
}
.outcome-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 24px;
  padding: 40px 32px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: all 0.4s var(--ease-out-expo);
}
.outcome-card:hover {
  transform: translateY(-6px);
  border-color: var(--border-glow);
  box-shadow: 0 24px 64px rgba(0,0,0,0.3);
}
.outcome-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  background: radial-gradient(circle at 50% 0%, rgba(138,63,252,0.06), transparent 60%);
  pointer-events: none;
}
.outcome-icon {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  margin: 0 auto 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.outcome-icon::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 24px;
  background: inherit;
  filter: blur(16px);
  opacity: 0.4;
  z-index: -1;
}
.outcome-icon.green { background: rgba(0,230,118,0.12); }
.outcome-icon.gold { background: var(--vault-gold-dim); }
.outcome-icon.purple { background: var(--purple-dim); }
.outcome-icon.red { background: var(--rh-red-dim); }

.outcome-value {
  font-size: clamp(36px, 4vw, 48px);
  font-weight: 900;
  line-height: 1;
  margin-bottom: 8px;
  letter-spacing: -0.03em;
}
.outcome-value.green { color: #00e676; }
.outcome-value.gold { color: var(--vault-gold); }
.outcome-value.purple { color: var(--purple); }
.outcome-value.red { color: var(--rh-red); }

.outcome-card h3 {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 8px;
  letter-spacing: -0.01em;
}
.outcome-card p {
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ============================================================
   FOOTER
   ============================================================ */
.footer {
  background: var(--bg-base);
  padding: 60px 0 40px;
  border-top: 1px solid var(--border-subtle);
}
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.footer-brand {
  display: flex;
  align-items: center;
  gap: 16px;
}
.footer-brand-logos {
  display: flex;
  align-items: center;
  gap: 12px;
}
.footer-brand span {
  font-size: 14px;
  color: var(--text-muted);
}
.footer-brand .x-mark {
  font-size: 18px;
  color: var(--text-muted);
  font-weight: 300;
}

.cert-badge {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  border-radius: 12px;
  background: var(--bg-card);
  border: 1px solid rgba(0,230,118,0.15);
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--text-secondary);
}
.cert-badge .lock-icon {
  color: #00e676;
}
.cert-badge .cn {
  color: #00e676;
  font-weight: 600;
}

.footer-meta {
  width: 100%;
  text-align: center;
  margin-top: 32px;
  padding-top: 24px;
  border-top: 1px solid var(--border-subtle);
  font-size: 13px;
  color: var(--text-muted);
}
.footer-hostname {
  font-family: var(--font-mono);
  color: var(--text-secondary);
}

/* ============================================================
   ANIMATED COUNTER STYLE
   ============================================================ */
.counter-animated {
  display: inline-block;
}

/* ============================================================
   RESPONSIVE REFINEMENTS
   ============================================================ */
@media (max-width: 768px) {
  .section { padding: 80px 0; }
  .hero { min-height: 100svh; }
  .hero-logos { gap: 20px; }
  .hero-logo-vault, .hero-logo-aap { width: 56px; height: 56px; }
  .solution-pillar { padding: 32px 24px; }
  .wheel-container { max-width: 320px; }
  .wheel-node { width: 64px; height: 64px; }
  .wheel-center { width: 80px; height: 80px; }
  .footer-inner { flex-direction: column; text-align: center; }
  .cert-badge { flex-wrap: wrap; justify-content: center; }
}

@media (max-width: 480px) {
  .problem-grid { grid-template-columns: 1fr; }
  .outcomes-grid { grid-template-columns: 1fr; }
  .hero h1 { font-size: 36px; }
  .wheel-container { max-width: 280px; }
  .wheel-node { width: 56px; height: 56px; }
  .wheel-node-label { font-size: 8px; }
}

/* ============================================================
   GLOW ACCENTS
   ============================================================ */
.glow-accent {
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.06;
  pointer-events: none;
}
</style>
