<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certificate Lifecycle Management — HashiCorp Vault + Red Hat Ansible</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap');

    /* ── Reset ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design tokens ─────────────────────────────────── */
    :root {
      --bg:             oklch(98% 0.005 50);
      --surface:        oklch(95% 0.008 50);
      --text:           oklch(18% 0.01 50);
      --text-secondary: oklch(45% 0.01 50);
      --border:         oklch(88% 0.008 50);
      --vault-gold:     #FFD814;
      --vault-dark:     #1A1A2E;
      --redhat-red:     #EE0000;

      /* 5-size type system */
      --step-0: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --step-1: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
      --step-2: clamp(1.75rem, 1.4rem + 1.75vw, 2.5rem);
      --step-3: clamp(2.5rem, 1.8rem + 3.5vw, 4rem);
      --step-4: clamp(3.5rem, 2.2rem + 6.5vw, 6.5rem);

      /* Fluid spacing */
      --space-xs:  clamp(0.5rem, 0.4rem + 0.5vw, 0.75rem);
      --space-s:   clamp(0.75rem, 0.6rem + 0.75vw, 1.25rem);
      --space-m:   clamp(1.5rem, 1rem + 2.5vw, 3rem);
      --space-l:   clamp(3rem, 2rem + 5vw, 6rem);
      --space-xl:  clamp(5rem, 3rem + 10vw, 10rem);

      --measure: 65ch;
    }

    /* ── Base ──────────────────────────────────────────── */
    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
    }

    body {
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      font-size: var(--step-0);
      font-weight: 400;
      line-height: 1.65;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── Utility ───────────────────────────────────────── */
    .wrap {
      width: min(90%, 72rem);
      margin-inline: auto;
      padding-inline: var(--space-s);
    }

    section {
      padding-block: var(--space-xl);
    }

    h1, h2, h3, h4 {
      font-family: 'Outfit', system-ui, -apple-system, sans-serif;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    p { max-width: var(--measure); }

    /* ── Scroll reveal ─────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(1.5rem);
      transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                  transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }

    /* ── HERO ──────────────────────────────────────────── */
    .hero {
      padding-block: var(--space-xl) var(--space-l);
      min-height: 85vh;
      display: flex;
      align-items: flex-end;
      padding-bottom: var(--space-l);
    }

    .hero-inner {
      display: grid;
      gap: var(--space-m);
    }

    .hero-logos {
      display: flex;
      align-items: center;
      gap: var(--space-m);
    }

    .hero-logos .logo-hashi {
      width: clamp(3rem, 2.5rem + 2.5vw, 4.5rem);
      color: var(--vault-gold);
    }

    .hero-logos .logo-redhat {
      width: clamp(4.5rem, 3.5rem + 4vw, 7rem);
    }

    .hero-logos .logo-separator {
      width: 1px;
      height: 2.5rem;
      background: var(--border);
    }

    .hero h1 {
      font-size: var(--step-3);
      font-weight: 800;
      max-width: 18ch;
    }

    .hero-sub {
      font-size: var(--step-1);
      color: var(--text-secondary);
      font-weight: 400;
      max-width: 48ch;
      line-height: 1.45;
    }

    .hero-rule {
      width: clamp(4rem, 3rem + 5vw, 8rem);
      height: 3px;
      background: var(--vault-gold);
      border: none;
      margin-top: var(--space-s);
    }

    /* ── PROBLEM ───────────────────────────────────────── */
    .problem {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .problem-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: var(--space-l);
    }

    .stat-list {
      display: grid;
      gap: var(--space-l);
    }

    .stat-item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-s) var(--space-m);
      align-items: baseline;
    }

    .stat-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-4);
      font-weight: 800;
      line-height: 1;
      color: var(--text);
    }

    .stat-body {
      padding-top: 0.35em;
    }

    .stat-desc {
      font-size: var(--step-1);
      font-weight: 500;
      color: var(--text);
      margin-bottom: var(--space-xs);
    }

    .stat-source {
      font-size: var(--step-0);
      color: var(--text-secondary);
      font-weight: 400;
    }

    @media (max-width: 640px) {
      .stat-item {
        grid-template-columns: 1fr;
        gap: var(--space-xs);
      }
    }

    /* ── BETTER TOGETHER ───────────────────────────────── */
    .together-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: var(--space-m);
    }

    .together-heading {
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-l);
      max-width: 20ch;
    }

    .together-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }

    @media (min-width: 768px) {
      .together-grid {
        grid-template-columns: 1.1fr 1px 1fr;
        gap: var(--space-m);
      }
    }

    .together-divider {
      background: var(--border);
      display: none;
    }

    @media (min-width: 768px) {
      .together-divider {
        display: block;
      }
    }

    .engine-section .engine-logo {
      margin-bottom: var(--space-s);
    }

    .engine-section .logo-hashi {
      width: 2.25rem;
      color: var(--vault-gold);
    }

    .engine-section .logo-redhat {
      width: 3.5rem;
    }

    .engine-title {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .engine-subtitle {
      font-size: var(--step-0);
      color: var(--text-secondary);
      font-weight: 500;
      margin-bottom: var(--space-m);
    }

    .engine-list {
      list-style: none;
      display: grid;
      gap: var(--space-s);
    }

    .engine-list li {
      position: relative;
      padding-left: 1.4em;
      line-height: 1.55;
    }

    .engine-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .vault-col .engine-list li::before {
      background: var(--vault-gold);
    }

    .aap-col .engine-list li::before {
      background: var(--redhat-red);
    }

    /* ── CAPABILITIES ──────────────────────────────────── */
    .capabilities {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .capabilities-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: var(--space-m);
    }

    .capabilities-heading {
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-l);
      max-width: 22ch;
    }

    .cap-list {
      display: grid;
      gap: 0;
    }

    .cap-item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-s) var(--space-m);
      align-items: baseline;
      padding-block: var(--space-m);
      border-top: 1px solid var(--border);
    }

    .cap-item:last-child {
      border-bottom: 1px solid var(--border);
    }

    .cap-marker {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-1);
      font-weight: 700;
      width: 2.5rem;
      height: 2.5rem;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--vault-gold);
      color: var(--vault-dark);
      line-height: 1;
      flex-shrink: 0;
    }

    .cap-content {
      padding-top: 0.15em;
    }

    .cap-name {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-1);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .cap-desc {
      color: var(--text-secondary);
      line-height: 1.6;
    }

    @media (max-width: 640px) {
      .cap-item {
        grid-template-columns: 1fr;
        gap: var(--space-xs);
      }
    }

    /* ── OUTCOMES ───────────────────────────────────────── */
    .outcomes-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      margin-bottom: var(--space-m);
    }

    .outcomes-heading {
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-l);
      max-width: 22ch;
    }

    .outcomes-list {
      display: grid;
      gap: var(--space-l);
    }

    @media (min-width: 768px) {
      .outcomes-list {
        grid-template-columns: 1fr 1fr;
        gap: var(--space-l) var(--space-xl);
      }
    }

    .outcome-big {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: var(--space-xs);
    }

    .outcome-big .accent-gold { color: oklch(55% 0.15 85); }
    .outcome-big .accent-red  { color: var(--redhat-red); }

    .outcome-text {
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* ── FOOTER ─────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding-block: var(--space-m);
    }

    .footer-inner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-s) var(--space-m);
    }

    .footer-left {
      display: flex;
      align-items: center;
      gap: var(--space-s);
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .footer-left .logo-hashi {
      width: 1.5rem;
      color: var(--vault-gold);
    }

    .footer-left .logo-redhat {
      width: 2.5rem;
    }

    .footer-right {
      font-size: 0.8125rem;
      color: var(--text-secondary);
    }

    .footer-host {
      font-family: 'DM Sans', monospace;
      font-weight: 500;
    }
  </style>
</head>
<body>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-logos reveal">
        <svg class="logo-hashi" viewBox="0 0 258.56 273.8" xmlns="http://www.w3.org/2000/svg" aria-label="HashiCorp">
          <path fill="currentColor" d="M107.77 0 0 62.21 0 62.26 0 211.54 40.47 234.95 40.47 85.56 107.77 46.71 107.77 0Z"/>
          <path fill="currentColor" d="M150.79 0 150.79 118.96 107.77 118.96 107.77 74.54 67.25 97.94 67.25 250.34 107.77 273.75 107.77 155.16 150.79 155.16 150.79 199.26 191.31 175.91 191.31 23.41 150.79 0Z"/>
          <path fill="currentColor" d="M150.79 273.8 258.56 211.64 258.56 211.59 258.56 62.31 218.09 38.91 218.09 188.24 150.79 227.09 150.79 273.8Z"/>
        </svg>
        <span class="logo-separator"></span>
        <svg class="logo-redhat" viewBox="0 0 193 146" xmlns="http://www.w3.org/2000/svg" aria-label="Red Hat">
          <path d="M127.47 83.49c12.51 0 30.61-2.58 30.61-17.46a14 14 0 0 0-.31-3.42l-7.45-32.36c-1.72-7.12-3.23-10.35-15.73-16.6C124.89 8.69 103.76.5 97.51.5 91.69.5 90 8 83.06 8c-6.68 0-11.64-5.6-17.89-5.6-6 0-9.91 4.09-12.93 12.5 0 0-8.41 23.72-9.49 27.16a6.43 6.43 0 0 0-.22 1.94c0 9.22 36.3 39.45 84.94 39.45M127.47 83.49z" fill="#EE0000"/>
          <path d="M127.47 83.49c-48.64 0-84.94-30.23-84.94-39.45a6.43 6.43 0 0 1 .22-1.94l-4.86 13.65c-.09.28-3.18 1.93-3.18 5.08 0 13.81 68.84 37.24 92.76 37.24s27-3.87 27-8.18c0-1.63-.78-3.74-.78-3.74-2.07 5.34-14.71 7.34-26.22 7.34" fill="#6c1d1d"/>
        </svg>
      </div>

      <h1 class="reveal reveal-delay-1">Eliminate Certificate Risk at Scale</h1>

      <p class="hero-sub reveal reveal-delay-2">HashiCorp Vault and Red Hat Ansible Automation Platform&thinsp;&mdash;&thinsp;automated certificate lifecycle management for the modern enterprise.</p>

      <hr class="hero-rule reveal reveal-delay-3">
    </div>
  </section>

  <!-- ════════════════ THE PROBLEM ════════════════ -->
  <section class="problem">
    <div class="wrap">
      <p class="problem-label reveal">The Problem</p>

      <div class="stat-list">
        <div class="stat-item reveal">
          <span class="stat-number">40%</span>
          <div class="stat-body">
            <p class="stat-desc">of enterprises face certificate-related outage risk each year</p>
            <p class="stat-source">CSC Research, 2024</p>
          </div>
        </div>

        <div class="stat-item reveal reveal-delay-1">
          <span class="stat-number">7,700+</span>
          <div class="stat-body">
            <p class="stat-desc">annual renewal operations per 1,000 certificates projected by 2029</p>
            <p class="stat-source">Certificate lifecycle complexity is accelerating</p>
          </div>
        </div>

        <div class="stat-item reveal reveal-delay-2">
          <span class="stat-number">6 hours</span>
          <div class="stat-body">
            <p class="stat-desc">Australian Parliament taken offline by a single expired certificate</p>
            <p class="stat-source">One overlooked renewal, nationwide impact</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ BETTER TOGETHER ════════════════ -->
  <section class="together">
    <div class="wrap">
      <p class="together-label reveal">Better Together</p>
      <h2 class="together-heading reveal reveal-delay-1">Two platforms, one automated workflow</h2>

      <div class="together-grid">
        <!-- Vault column -->
        <div class="engine-section vault-col reveal reveal-delay-2">
          <div class="engine-logo">
            <svg class="logo-hashi" viewBox="0 0 258.56 273.8" xmlns="http://www.w3.org/2000/svg" aria-label="HashiCorp Vault">
              <path fill="currentColor" d="M107.77 0 0 62.21 0 62.26 0 211.54 40.47 234.95 40.47 85.56 107.77 46.71 107.77 0Z"/>
              <path fill="currentColor" d="M150.79 0 150.79 118.96 107.77 118.96 107.77 74.54 67.25 97.94 67.25 250.34 107.77 273.75 107.77 155.16 150.79 155.16 150.79 199.26 191.31 175.91 191.31 23.41 150.79 0Z"/>
              <path fill="currentColor" d="M150.79 273.8 258.56 211.64 258.56 211.59 258.56 62.31 218.09 38.91 218.09 188.24 150.79 227.09 150.79 273.8Z"/>
            </svg>
          </div>
          <h3 class="engine-title">Vault</h3>
          <p class="engine-subtitle">The Trust Engine</p>
          <ul class="engine-list">
            <li>Built-in PKI secrets engine with full CA hierarchy</li>
            <li>Automated certificate issuance with configurable TTLs</li>
            <li>Centralized policy enforcement and audit logging</li>
            <li>Dynamic secrets eliminate long-lived credentials</li>
            <li>API-first design for seamless automation</li>
          </ul>
        </div>

        <div class="together-divider"></div>

        <!-- AAP column -->
        <div class="engine-section aap-col reveal reveal-delay-3">
          <div class="engine-logo">
            <svg class="logo-redhat" viewBox="0 0 193 146" xmlns="http://www.w3.org/2000/svg" aria-label="Red Hat Ansible">
              <path d="M127.47 83.49c12.51 0 30.61-2.58 30.61-17.46a14 14 0 0 0-.31-3.42l-7.45-32.36c-1.72-7.12-3.23-10.35-15.73-16.6C124.89 8.69 103.76.5 97.51.5 91.69.5 90 8 83.06 8c-6.68 0-11.64-5.6-17.89-5.6-6 0-9.91 4.09-12.93 12.5 0 0-8.41 23.72-9.49 27.16a6.43 6.43 0 0 0-.22 1.94c0 9.22 36.3 39.45 84.94 39.45M127.47 83.49z" fill="#EE0000"/>
              <path d="M127.47 83.49c-48.64 0-84.94-30.23-84.94-39.45a6.43 6.43 0 0 1 .22-1.94l-4.86 13.65c-.09.28-3.18 1.93-3.18 5.08 0 13.81 68.84 37.24 92.76 37.24s27-3.87 27-8.18c0-1.63-.78-3.74-.78-3.74-2.07 5.34-14.71 7.34-26.22 7.34" fill="#6c1d1d"/>
            </svg>
          </div>
          <h3 class="engine-title">Ansible Automation Platform</h3>
          <p class="engine-subtitle">The Automation Engine</p>
          <ul class="engine-list">
            <li>Agentless push-based execution across any infrastructure</li>
            <li>Declarative playbooks for repeatable certificate workflows</li>
            <li>Role-based access control with approval workflows</li>
            <li>Scheduled jobs for proactive certificate monitoring</li>
            <li>Event-driven automation for real-time response</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FIVE CAPABILITIES ════════════════ -->
  <section class="capabilities">
    <div class="wrap">
      <p class="capabilities-label reveal">Lifecycle</p>
      <h2 class="capabilities-heading reveal reveal-delay-1">Five capabilities, fully automated</h2>

      <div class="cap-list">
        <div class="cap-item reveal">
          <span class="cap-marker">1</span>
          <div class="cap-content">
            <p class="cap-name">Issue</p>
            <p class="cap-desc">Vault's PKI engine generates certificates on demand with enforced policies, delivering them to any endpoint through Ansible playbooks.</p>
          </div>
        </div>

        <div class="cap-item reveal reveal-delay-1">
          <span class="cap-marker">2</span>
          <div class="cap-content">
            <p class="cap-name">Monitor</p>
            <p class="cap-desc">Scheduled Ansible jobs continuously scan certificate expiration dates and surface renewal windows before they become emergencies.</p>
          </div>
        </div>

        <div class="cap-item reveal reveal-delay-2">
          <span class="cap-marker">3</span>
          <div class="cap-content">
            <p class="cap-name">Renew</p>
            <p class="cap-desc">When certificates approach expiration, automation requests fresh certificates from Vault and deploys them with zero manual intervention.</p>
          </div>
        </div>

        <div class="cap-item reveal reveal-delay-3">
          <span class="cap-marker">4</span>
          <div class="cap-content">
            <p class="cap-name">Revoke</p>
            <p class="cap-desc">Compromised or decommissioned certificates are immediately revoked in Vault and purged from every endpoint in a single workflow.</p>
          </div>
        </div>

        <div class="cap-item reveal reveal-delay-4">
          <span class="cap-marker">5</span>
          <div class="cap-content">
            <p class="cap-name">Rollback</p>
            <p class="cap-desc">If a new certificate causes issues, Ansible restores the previous certificate from backup and triggers re-issuance, keeping services online.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ BUSINESS OUTCOMES ════════════════ -->
  <section class="outcomes">
    <div class="wrap">
      <p class="outcomes-label reveal">Outcomes</p>
      <h2 class="outcomes-heading reveal reveal-delay-1">What changes when certificates manage themselves</h2>

      <div class="outcomes-list">
        <div class="outcome-item reveal">
          <p class="outcome-big">Zero unplanned <span class="accent-gold">outages</span></p>
          <p class="outcome-text">Proactive monitoring and automated renewal eliminate the forgotten-certificate failure mode entirely.</p>
        </div>

        <div class="outcome-item reveal reveal-delay-1">
          <p class="outcome-big">Minutes, not <span class="accent-red">weeks</span></p>
          <p class="outcome-text">Certificate operations that took days of ticket queues now execute in minutes through self-service automation.</p>
        </div>

        <div class="outcome-item reveal reveal-delay-2">
          <p class="outcome-big">Audit-ready <span class="accent-gold">always</span></p>
          <p class="outcome-text">Every issuance, renewal, and revocation is logged in Vault with a complete chain of custody for compliance.</p>
        </div>

        <div class="outcome-item reveal reveal-delay-3">
          <p class="outcome-big">Scale without <span class="accent-red">headcount</span></p>
          <p class="outcome-text">Manage thousands of certificates with the same team. Automation absorbs growth that would otherwise demand hiring.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════ FOOTER ════════════════ -->
