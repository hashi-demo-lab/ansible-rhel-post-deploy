  <script>
    (function () {
      'use strict';

      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Utility: IntersectionObserver factory ──────────
      function createObserver(callback, options) {
        return new IntersectionObserver(callback, options);
      }

      // ── 1. Hero word-by-word reveal ───────────────────
      (function heroReveal() {
        var words = document.querySelectorAll('.hero-word');
        var line = document.querySelector('.hero-line-draw');
        var heroSub = document.querySelector('.hero-sub');

        if (prefersReduced) {
          words.forEach(function (w) { w.classList.add('word-visible'); });
          if (line) line.classList.add('line-visible');
          if (heroSub) heroSub.classList.add('visible');
          return;
        }

        words.forEach(function (word, i) {
          setTimeout(function () {
            word.classList.add('word-visible');
          }, 300 + i * 150);
        });

        setTimeout(function () {
          if (heroSub) heroSub.classList.add('visible');
        }, 300 + words.length * 150 + 200);

        setTimeout(function () {
          if (line) line.classList.add('line-visible');
        }, 300 + words.length * 150 + 100);
      })();

      // ── 2. Scroll reveal observer ─────────────────────
      if (!prefersReduced) {
        var revealObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal, .reveal-slide-left').forEach(function (el) {
          revealObs.observe(el);
        });
      } else {
        document.querySelectorAll('.reveal, .reveal-slide-left').forEach(function (el) {
          el.classList.add('visible');
        });
      }

      // ── 3. Animated counters ──────────────────────────
      (function animateCounters() {
        var counters = document.querySelectorAll('.counter');
        if (prefersReduced) {
          counters.forEach(function (c) {
            var t = parseInt(c.getAttribute('data-target'), 10);
            var s = c.getAttribute('data-suffix') || '';
            var sep = c.getAttribute('data-separator');
            c.textContent = (sep ? t.toLocaleString() : t) + s;
          });
          return;
        }

        var counterObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var el = entry.target;
            counterObs.unobserve(el);
            var target = parseInt(el.getAttribute('data-target'), 10);
            var suffix = el.getAttribute('data-suffix') || '';
            var sep = el.getAttribute('data-separator');
            var start = 0;
            var duration = 1500;
            var startTime = null;

            function step(timestamp) {
              if (!startTime) startTime = timestamp;
              var progress = Math.min((timestamp - startTime) / duration, 1);
              var eased = 1 - Math.pow(1 - progress, 4);
              var current = Math.round(start + (target - start) * eased);
              el.textContent = (sep ? current.toLocaleString() : current) + suffix;
              if (progress < 1) requestAnimationFrame(step);
            }

            requestAnimationFrame(step);
          });
        }, { threshold: 0.3 });

        counters.forEach(function (c) { counterObs.observe(c); });

        // Mega stat animation
        var megaStats = document.querySelectorAll('.stat-mega');
        var megaObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('counter-visible');
              megaObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.2 });

        megaStats.forEach(function (m) { megaObs.observe(m); });
      })();

      // ── 4. SVG underline reveal ───────────────────────
      (function svgUnderlines() {
        var underlines = document.querySelectorAll('.svg-underline');
        if (prefersReduced) {
          underlines.forEach(function (u) { u.classList.add('underline-visible'); });
          return;
        }

        var underlineObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('underline-visible');
              underlineObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });

        underlines.forEach(function (u) { underlineObs.observe(u); });
      })();

      // ── 5. Bridge line draw ───────────────────────────
      (function bridgeDraw() {
        var bridges = document.querySelectorAll('[data-bridge]');
        if (prefersReduced) {
          bridges.forEach(function (b) {
            b.querySelector('.bridge-line').classList.add('bridge-drawn');
          });
          return;
        }

        var bridgeObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var line = entry.target.querySelector('.bridge-line');
            var pulse = entry.target.querySelector('.bridge-pulse');
            if (line) line.classList.add('bridge-drawn');
            if (pulse) pulse.classList.add('bridge-pulse-active');
            bridgeObs.unobserve(entry.target);
          });
        }, { threshold: 0.3 });

        bridges.forEach(function (b) { bridgeObs.observe(b); });
      })();

      // ── 6. Staggered list items ───────────────────────
      (function staggerLists() {
        var lists = document.querySelectorAll('[data-stagger-list]');
        if (prefersReduced) {
          lists.forEach(function (l) {
            l.querySelectorAll('li').forEach(function (li) { li.classList.add('visible'); });
          });
          return;
        }

        var listObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var items = entry.target.querySelectorAll('li');
            items.forEach(function (li, i) {
              setTimeout(function () { li.classList.add('visible'); }, i * 120);
            });
            listObs.unobserve(entry.target);
          });
        }, { threshold: 0.2 });

        lists.forEach(function (l) { listObs.observe(l); });
      })();

      // ── 7. Chapter nav highlighting ───────────────────
      (function chapterNav() {
        var sections = document.querySelectorAll('[data-section]');
        var navLinks = document.querySelectorAll('.chapter-nav a');
        if (!navLinks.length) return;

        var navObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var id = entry.target.getAttribute('data-section');
              navLinks.forEach(function (link) {
                link.classList.toggle('active', link.getAttribute('data-chapter') === id);
              });
            }
          });
        }, { threshold: 0, rootMargin: '-40% 0px -55% 0px' });

        sections.forEach(function (s) { navObs.observe(s); });
      })();

      // ── 8. Parallax scroll ────────────────────────────
      (function parallaxScroll() {
        if (prefersReduced) return;

        var layers = document.querySelectorAll('.parallax-layer');
        if (!layers.length) return;

        var ticking = false;

        function updateParallax() {
          var scrollY = window.pageYOffset;
          layers.forEach(function (layer) {
            var speed = parseFloat(layer.getAttribute('data-speed')) || 0.03;
            var rect = layer.parentElement.getBoundingClientRect();
            var offset = (rect.top + window.pageYOffset) - scrollY;
            layer.style.transform = 'translateY(' + (offset * speed) + 'px)';
          });
          ticking = false;
        }

        window.addEventListener('scroll', function () {
          if (!ticking) {
            requestAnimationFrame(updateParallax);
            ticking = true;
          }
        }, { passive: true });
      })();

      // ── 9. Mouse-responsive logos ─────────────────────
      (function mouseTrack() {
        if (prefersReduced) return;

        var tracked = document.querySelectorAll('.logo-mouse-track');
        if (!tracked.length) return;

        var centerX = window.innerWidth / 2;
        var centerY = window.innerHeight / 2;
        var ticking = false;
        var mouseX = centerX;
        var mouseY = centerY;

        window.addEventListener('resize', function () {
          centerX = window.innerWidth / 2;
          centerY = window.innerHeight / 2;
        });

        document.addEventListener('mousemove', function (e) {
          mouseX = e.clientX;
          mouseY = e.clientY;

          if (!ticking) {
            requestAnimationFrame(function () {
              tracked.forEach(function (el) {
                var strength = parseFloat(el.getAttribute('data-track-strength')) || 5;
                var dx = ((mouseX - centerX) / centerX) * strength;
                var dy = ((mouseY - centerY) / centerY) * strength;
                el.style.transform = 'translate(' + dx + 'px, ' + dy + 'px)';
              });
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      })();

      // ── 10. Footer lock animation ─────────────────────
      (function lockAnimation() {
        var lockIcon = document.querySelector('[data-lock-icon]');
        if (!lockIcon) return;

        if (prefersReduced) {
          lockIcon.classList.add('lock-closed');
          return;
        }

        var lockObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              setTimeout(function () {
                lockIcon.classList.add('lock-closed');
              }, 400);
              lockObs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });

        lockObs.observe(lockIcon);
      })();

      // ── 11. Footer hostname typewriter ────────────────
      (function typewriter() {
        var el = document.querySelector('[data-typewriter]');
        if (!el) return;

        var text = el.textContent.trim();
        el.textContent = '';

        var chars = [];
        for (var i = 0; i < text.length; i++) {
          var span = document.createElement('span');
          span.className = 'typewriter-char';
          span.textContent = text[i];
          el.appendChild(span);
          chars.push(span);
        }

        if (prefersReduced) {
          chars.forEach(function (c) { c.classList.add('char-visible'); });
          return;
        }

        var typeObs = createObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            chars.forEach(function (c, idx) {
              setTimeout(function () {
                c.classList.add('char-visible');
              }, 600 + idx * 60);
            });
            typeObs.unobserve(entry.target);
          });
        }, { threshold: 0.5 });

        typeObs.observe(el);
      })();

    })();
  </script>
</body>
</html>
