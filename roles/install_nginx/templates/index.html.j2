<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certificate Lifecycle Management — HashiCorp Vault + Red Hat Ansible</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ── Reset ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design Tokens ────────────────────────────────── */
    :root {
      --bg:          oklch(97.5% 0.005 55);
      --bg-alt:      oklch(95% 0.008 55);
      --bg-warm:     oklch(96% 0.015 80);
      --bg-cool:     oklch(96.5% 0.008 240);
      --bg-light:    oklch(98.5% 0.003 55);
      --text:        oklch(18% 0.01 55);
      --text-muted:  oklch(45% 0.01 55);
      --text-faint:  oklch(65% 0.008 55);
      --vault-gold:  #FFD814;
      --vault-dark:  #1A1A2E;
      --redhat-red:  #EE0000;
      --accent:      oklch(55% 0.15 270);
      --border:      oklch(88% 0.008 55);

      --step-0: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --step-1: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
      --step-2: clamp(1.75rem, 1.4rem + 1.75vw, 2.5rem);
      --step-3: clamp(2.5rem, 1.8rem + 3.5vw, 4rem);
      --step-4: clamp(3.5rem, 2.2rem + 6.5vw, 6.5rem);
      --step-hero: clamp(3rem, 2rem + 5vw, 5.5rem);

      --space-xs:  clamp(0.5rem, 0.4rem + 0.5vw, 0.75rem);
      --space-s:   clamp(0.75rem, 0.6rem + 0.75vw, 1.25rem);
      --space-m:   clamp(1.5rem, 1rem + 2.5vw, 3rem);
      --space-l:   clamp(3rem, 2rem + 5vw, 6rem);
      --space-xl:  clamp(5rem, 3rem + 10vw, 10rem);

      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      --measure: 65ch;
    }

    /* ── Base ──────────────────────────────────────────── */
    html {
      -webkit-text-size-adjust: 100%;
      overflow: hidden;
      height: 100%;
    }

    body {
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      font-size: var(--step-0);
      font-weight: 400;
      line-height: 1.65;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
      height: 100%;
    }

    h1, h2, h3, h4 {
      font-family: 'Outfit', system-ui, -apple-system, sans-serif;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    p { max-width: var(--measure); }

    /* ── Horizontal Slide Track ─────────────────────────── */
    .slide-track {
      display: flex;
      height: 100vh;
      width: calc(10 * 100vw);
      transition: transform 1.1s var(--ease-out-quart);
      will-change: transform;
    }

    /* ── Progress Bar (top, horizontal) ─────────────────── */
    .progress-bar {
      position: fixed;
      top: 0;
      left: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--vault-gold), var(--accent));
      box-shadow: 0 0 8px oklch(55% 0.15 270 / 0.4);
      z-index: 200;
      width: 0%;
      transition: width 0.4s var(--ease-out-expo);
      will-change: width;
    }

    /* ── Chapter Side Navigation (left rail) ─────────────── */
    .chapter-nav {
      position: fixed;
      top: 50%;
      left: clamp(0.6rem, 1.2vw, 1.2rem);
      transform: translateY(-50%);
      z-index: 100;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    .chapter-nav a {
      display: flex;
      align-items: center;
      flex-direction: row;
      gap: 0.5rem;
      text-decoration: none;
      color: var(--text-faint);
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      transition: color 0.3s var(--ease-out-expo);
    }

    .chapter-nav a .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--border);
      transition: background 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
      flex-shrink: 0;
      position: relative;
    }

    .chapter-nav a .dot svg {
      position: absolute;
      inset: -4px;
      width: calc(100% + 8px);
      height: calc(100% + 8px);
    }
    .chapter-nav .dot svg circle.progress {
      stroke-dasharray: 44;
      stroke-dashoffset: 44;
      transition: stroke-dashoffset 0.3s var(--ease-out-quart);
      stroke: var(--accent);
      fill: none;
      stroke-width: 2;
      transform: rotate(-90deg);
      transform-origin: center;
    }

    .chapter-nav a .label {
      opacity: 0;
      transform: translateX(-4px);
      transition: opacity 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
      white-space: nowrap;
      text-transform: uppercase;
    }

    .chapter-nav a:hover .label,
    .chapter-nav a.active .label {
      opacity: 1;
      transform: translateX(0);
    }

    .chapter-nav a:hover .dot { background: var(--text-muted); }
    .chapter-nav a.active .dot {
      background: var(--accent);
      transform: scale(1.4);
    }
    .chapter-nav a.active { color: var(--text); }

    @media (max-width: 768px) {
      .chapter-nav .label { display: none; }
      .chapter-nav { gap: 0.6rem; left: 0.4rem; }
    }

    /* ── Slide (full-viewport section) ────────────────── */
    .slide {
      width: 100vw;
      height: 100vh;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--space-l) 0;
      position: relative;
      overflow: hidden;
      overflow-y: auto;
    }

    .wrap {
      width: min(90%, 72rem);
      margin-inline: auto;
      padding-inline: var(--space-s);
    }

    /* ── Reveal Animations ────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateX(3rem);
      transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateX(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }
    .reveal-delay-6 { transition-delay: 0.6s; }
    .reveal-delay-7 { transition-delay: 0.7s; }
    .reveal-delay-8 { transition-delay: 0.8s; }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .hero-word { opacity: 1 !important; transform: none !important; }
      .scroll-hint { animation: none !important; }
      .counter { transition: none !important; }
    }

    /* ── Slide Backgrounds ────────────────────────────── */
    .slide--hero { background: var(--bg); }
    .slide--risk { background: var(--bg-warm); }
    .slide--shift { background: var(--bg-warm); }
    .slide--together { background: var(--bg); }
    .slide--lifecycle { background: var(--bg-alt); }
    .slide--architecture { background: var(--bg-cool); }

    /* Architecture diagram phase highlighting */
    #archSvg .arch-monitor,
    #archSvg .arch-deploy {
      transition: opacity 0.6s var(--ease-out-expo);
    }
    #archSvg.arch-highlight-monitor .arch-deploy { opacity: 0.12; }
    #archSvg.arch-highlight-deploy .arch-monitor { opacity: 0.12; }

    .arch-phase-label {
      position: absolute;
      top: -1.6rem;
      left: 0;
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.05em;
      opacity: 0;
      transition: opacity 0.4s var(--ease-out-expo);
    }
    .arch-phase-label.visible { opacity: 1; }
    .slide--resilience { background: var(--bg-cool); }
    .slide--outcomes { background: var(--bg); }
    .slide--benefits { background: var(--bg-warm); }
    .slide--cta { background: var(--bg-alt); }

    /* ── Hero ──────────────────────────────────────────── */
    .hero-headline {
      font-size: var(--step-hero);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: var(--space-m);
    }

    .hero-word {
      display: inline-block;
      opacity: 0;
      transform: translateY(1.5rem);
      transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
    }

    .hero-word.show {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-logos {
      display: flex;
      align-items: center;
      gap: var(--space-m);
      margin-bottom: var(--space-m);
    }

    .hero-logos svg { height: clamp(2rem, 3vw, 3rem); }
    .hero-logos .hashicorp-logo { color: var(--text); }
    .hero-logos .logo-divider {
      width: 1px;
      height: 2rem;
      background: var(--border);
    }

    .hero-subtitle {
      font-size: var(--step-1);
      color: var(--text-muted);
      margin-bottom: var(--space-l);
    }

    .scroll-hint {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.875rem;
      color: var(--text-faint);
      font-family: 'Outfit', system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: 0.03em;
    }

    .scroll-hint .arrow {
      display: inline-block;
      animation: bounce-right 2s var(--ease-out-expo) infinite;
    }

    @keyframes bounce-right {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(6px); }
    }

    /* ── Section Headers ──────────────────────────────── */
    .section-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: var(--space-s);
    }

    .section-title {
      font-size: var(--step-3);
      font-weight: 800;
      margin-bottom: var(--space-m);
      max-width: 20ch;
    }

    /* ── Risk Section (Chapter 2) ─────────────────────── */
    .risk-hero-quote {
      position: relative;
      padding: var(--space-l) var(--space-l) var(--space-m);
      margin-bottom: var(--space-m);
      background: linear-gradient(135deg, oklch(16% 0.02 25), oklch(22% 0.03 25));
      border-radius: 1rem;
      overflow: hidden;
    }

    .risk-hero-quote::before {
      content: '\201C';
      position: absolute;
      top: -0.2em;
      left: 0.6rem;
      font-family: 'Outfit', serif;
      font-size: clamp(8rem, 15vw, 14rem);
      font-weight: 800;
      color: var(--redhat-red);
      opacity: 0.15;
      line-height: 1;
      pointer-events: none;
    }

    .risk-hero-quote::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 6px;
      height: 100%;
      background: var(--redhat-red);
    }

    .risk-hero-quote blockquote {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(1.15rem, 1rem + 0.8vw, 1.6rem);
      font-weight: 600;
      line-height: 1.5;
      color: oklch(95% 0.005 55);
      font-style: normal;
      max-width: none;
      position: relative;
      z-index: 1;
    }

    .risk-hero-quote .incident-source {
      font-size: 0.9rem;
      color: oklch(70% 0.02 25);
      font-weight: 600;
      margin-top: var(--space-s);
      font-style: normal;
      position: relative;
      z-index: 1;
    }

    .incident-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-xs);
      margin-bottom: var(--space-m);
    }

    .incident-card {
      background: var(--bg-light);
      padding: var(--space-s) var(--space-s);
      border-radius: 0.5rem;
      border: 1px solid var(--border);
      border-top: 3px solid var(--redhat-red);
    }

    .incident-card strong {
      display: block;
      font-family: 'Outfit', system-ui, sans-serif;
      font-weight: 700;
      font-size: 0.875rem;
      margin-bottom: 0.25rem;
    }

    .incident-card span {
      font-size: 0.8125rem;
      color: var(--text-muted);
    }

    .risk-stat {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
    }

    .risk-stat .counter-value { color: var(--redhat-red); }

    .risk-stat-source {
      font-size: 0.8125rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ── 47-Day Shift Section ─────────────────────────── */
    .shift-lead {
      font-size: var(--step-0);
      color: var(--text);
      max-width: var(--measure);
      margin-bottom: var(--space-s);
    }

    .timeline {
      display: flex;
      align-items: stretch;
      gap: 0;
      margin: var(--space-s) 0;
      position: relative;
    }

    .timeline::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--border);
    }

    .timeline-step {
      flex: 1;
      text-align: center;
      position: relative;
      padding: 0 var(--space-xs);
    }

    .timeline-step .marker {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--border);
      margin: -7px auto var(--space-s);
      position: relative;
      z-index: 2;
      transition: background 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    }

    .timeline-step.past .marker {
      background: var(--text-faint);
    }

    .timeline-step.past .timeline-days {
      color: var(--text-faint);
    }

    .timeline-step.active .marker {
      background: var(--vault-gold);
      transform: scale(1.3);
    }

    .timeline-step.active .marker::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      border: 2px solid var(--vault-gold);
      animation: markerRadiate 2.5s ease-out infinite;
    }

    @keyframes markerRadiate {
      0% { transform: scale(1); opacity: 0.6; }
      100% { transform: scale(2.4); opacity: 0; }
    }

    .timeline-step.future .marker { background: var(--accent); }

    .timeline-days {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      color: var(--text);
    }

    .timeline-date {
      font-size: 0.8125rem;
      color: oklch(60% 0.008 55);
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .shift-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
      gap: var(--space-s);
      margin: var(--space-s) 0;
    }

    .shift-stat-block {
      padding: var(--space-s);
      background: var(--bg-light);
      border-radius: 0.75rem;
      border: 1px solid var(--border);
    }

    .shift-stat-block .big-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      color: var(--accent);
    }

    .shift-stat-block p {
      color: var(--text-muted);
      font-size: 0.8125rem;
      margin-top: 0.35rem;
      line-height: 1.5;
    }

    .shift-insight {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 700;
      color: var(--text);
      margin: var(--space-xs) 0;
      max-width: var(--measure);
    }

    .shift-callout {
      margin: var(--space-s) 0;
      padding: var(--space-s) var(--space-s) var(--space-s) var(--space-s);
      border-left: 4px solid var(--accent);
      background: oklch(93% 0.015 270 / 0.3);
      border-radius: 0 0.5rem 0.5rem 0;
    }

    .shift-callout .callout-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.25rem;
    }

    .shift-callout .callout-text {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-1);
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
    }

    .shift-callout .callout-sub {
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 0.8125rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
      max-width: var(--measure);
      line-height: 1.45;
    }

    .shift-source {
      font-size: 0.7rem;
      color: var(--text-faint);
      margin-top: var(--space-xs);
    }

    /* ── Better Together ──────────────────────────────── */
    .together-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: var(--space-m);
      align-items: center;
      margin-top: var(--space-m);
    }

    @media (max-width: 768px) {
      .together-grid {
        grid-template-columns: 1fr;
      }
      .bridge-connector { display: none !important; }
    }

    .engine-card {
      padding: var(--space-m);
      border-radius: 1rem;
      border: 1px solid var(--border);
      background: var(--bg-light);
    }

    .engine-card .engine-logo {
      height: 2.5rem;
      margin-bottom: var(--space-s);
    }

    .engine-card .engine-role {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    .engine-card h3 {
      font-size: var(--step-2);
      font-weight: 800;
      margin-bottom: var(--space-s);
    }

    .engine-card ul {
      list-style: none;
      padding: 0;
    }

    .engine-card ul li {
      padding: 0.4rem 0;
      font-size: 0.9375rem;
      color: var(--text-muted);
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .engine-card ul li::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 0.5em;
    }

    .engine-card.vault ul li::before { background: var(--vault-gold); }
    .engine-card.ansible ul li::before { background: var(--redhat-red); }

    .bridge-connector {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .bridge-connector svg {
      width: clamp(3rem, 6vw, 6rem);
      color: var(--accent);
    }

    .bridge-connector span {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-faint);
      writing-mode: vertical-lr;
      text-orientation: mixed;
    }

    /* ── Lifecycle (Chapter 5) ────────────────────────── */
    .lifecycle-container {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-m);
      margin-top: var(--space-s);
      align-items: center;
    }

    .lifecycle-wheel-wrap {
      position: relative;
      width: clamp(400px, 50vw, 650px);
      height: clamp(400px, 50vw, 650px);
    }

    .lifecycle-wheel-wrap svg {
      width: 100%;
      height: 100%;
    }

    .lifecycle-node {
      cursor: pointer;
      transition: transform 0.3s var(--ease-out-expo);
    }

    .lifecycle-node:hover .node-ring {
      stroke-width: 4;
    }

    .lifecycle-node.active .node-ring {
      stroke-width: 5;
    }

    .lifecycle-node .node-bg {
      transition: opacity 0.3s ease;
      opacity: 0.06;
    }

    .lifecycle-node:hover .node-bg,
    .lifecycle-node.active .node-bg {
      opacity: 0.15;
    }

    /* Connector lines from center to nodes */
    .connector-line {
      stroke: oklch(80% 0.008 55);
      stroke-width: 1.5;
      transition: stroke 0.4s var(--ease-out-expo), stroke-width 0.4s var(--ease-out-expo), filter 0.4s var(--ease-out-expo);
      filter: none;
    }

    .connector-line.active,
    .connector-line.hovered {
      stroke-width: 3;
      filter: drop-shadow(0 0 6px var(--line-color, oklch(55% 0.15 270)));
    }

    .connector-particle {
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .connector-particle.active,
    .connector-particle.hovered {
      opacity: 1;
    }

    .lifecycle-detail {
      min-width: 0;
    }

    .lifecycle-detail-panel {
      display: none;
      opacity: 0;
      transform: translateX(1rem);
    }

    .lifecycle-detail-panel.active {
      display: block;
      opacity: 1;
      transform: translateX(0);
      animation: fadeSlideIn 0.4s var(--ease-out-expo);
    }

    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateX(1rem); }
      to { opacity: 1; transform: translateX(0); }
    }

    .lifecycle-detail-panel h3 {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .lifecycle-detail-panel .capability-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-0);
      font-weight: 600;
      color: var(--text-faint);
      margin-bottom: var(--space-xs);
    }

    .lifecycle-detail-panel p {
      font-size: clamp(1rem, 0.9rem + 0.3vw, 1.15rem);
      color: var(--text-muted);
      max-width: none;
      line-height: 1.7;
      margin-bottom: var(--space-s);
    }

    .lifecycle-detail-panel ul {
      list-style: none;
      padding: 0;
    }

    .lifecycle-detail-panel ul li {
      font-size: clamp(0.95rem, 0.85rem + 0.25vw, 1.1rem);
      color: var(--text-muted);
      padding: 0.4rem 0;
      padding-left: 1.5rem;
      position: relative;
    }

    .lifecycle-detail-panel ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.7rem;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--dot-color, var(--text-faint));
    }

    .lifecycle-hint {
      font-size: 0.875rem;
      color: var(--text-faint);
      margin-top: var(--space-s);
      font-style: italic;
    }

    @media (max-width: 768px) {
      .lifecycle-container {
        flex-direction: column;
      }
      .lifecycle-wheel-wrap {
        width: 300px;
        height: 300px;
      }
      .incident-grid {
        grid-template-columns: 1fr;
      }
    }

    /* ── Resilience (Chapter 7) — Stacked Shield Layers ── */
    .resilience-stack {
      position: relative;
      margin-top: var(--space-s);
      perspective: 800px;
    }

    .shield-layer {
      position: relative;
      padding: var(--space-s) var(--space-m);
      border-radius: 1rem;
      margin-bottom: -1rem;
      transition: transform 0.5s var(--ease-out-expo), box-shadow 0.5s var(--ease-out-expo);
    }

    .shield-layer:hover {
      transform: translateY(-4px) scale(1.005);
    }

    .shield-layer:nth-child(1) {
      background: linear-gradient(135deg, oklch(94% 0.02 240), oklch(96% 0.015 240));
      border: 1px solid oklch(88% 0.03 240);
      box-shadow: 0 8px 32px oklch(55% 0.05 240 / 0.12);
      z-index: 3;
    }

    .shield-layer:nth-child(2) {
      background: linear-gradient(135deg, oklch(93% 0.02 270), oklch(95.5% 0.015 270));
      border: 1px solid oklch(87% 0.03 270);
      box-shadow: 0 12px 40px oklch(55% 0.05 270 / 0.1);
      z-index: 2;
      margin-left: 1.5rem;
      margin-right: -1.5rem;
    }

    .shield-layer:nth-child(3) {
      background: linear-gradient(135deg, oklch(92% 0.02 160), oklch(95% 0.015 160));
      border: 1px solid oklch(86% 0.03 160);
      box-shadow: 0 16px 48px oklch(55% 0.05 160 / 0.08);
      z-index: 1;
      margin-left: 3rem;
      margin-right: -3rem;
      margin-bottom: 0;
    }

    .shield-layer .shield-icon {
      font-size: 1.5rem;
      margin-bottom: 0.25rem;
      display: block;
    }

    .shield-layer .shield-num {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-faint);
      margin-bottom: 0.15rem;
    }

    .shield-layer h3 {
      font-size: var(--step-1);
      font-weight: 800;
      margin-bottom: 0.25rem;
    }

    .shield-layer p {
      font-size: 0.875rem;
      color: var(--text-muted);
      max-width: 50ch;
      line-height: 1.45;
    }

    .resilience-motto {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      margin-top: calc(var(--space-s) + 1rem);
      background: linear-gradient(135deg, oklch(45% 0.12 240), oklch(50% 0.15 270));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Outcomes (Chapter 7) ─────────────────────────── */
    .outcomes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
      gap: var(--space-m);
      margin-top: var(--space-m);
    }

    .outcome-item {
      text-align: left;
    }

    .outcome-item .outcome-value {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-3);
      font-weight: 800;
      line-height: 1;
      margin-bottom: 0.5rem;
      color: var(--text);
    }

    .outcome-item .outcome-label {
      font-size: 0.9375rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ── Who Benefits (Chapter 8) — Expanding Panels ──── */
    .benefits-panels {
      display: flex;
      gap: 0.75rem;
      margin-top: var(--space-m);
      height: clamp(26rem, 55vh, 38rem);
    }

    .benefit-panel {
      flex: 1.5;
      min-width: 0;
      border-radius: 1rem;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      transition: flex 0.6s var(--ease-out-expo);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: var(--space-m) var(--space-m);
    }

    .benefit-panel.expanded {
      flex: 5;
      padding: var(--space-m) var(--space-l);
    }

    .benefit-panel--security {
      background: linear-gradient(160deg, oklch(35% 0.1 270), oklch(25% 0.08 280));
    }

    .benefit-panel--platform {
      background: linear-gradient(160deg, oklch(35% 0.08 170), oklch(25% 0.06 180));
    }

    .benefit-panel--leadership {
      background: linear-gradient(160deg, oklch(40% 0.08 70), oklch(30% 0.06 60));
    }

    .benefit-panel .panel-stripe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 5px;
    }

    .benefit-panel--security .panel-stripe {
      background: linear-gradient(90deg, oklch(60% 0.18 270), oklch(70% 0.14 300));
    }
    .benefit-panel--platform .panel-stripe {
      background: linear-gradient(90deg, oklch(60% 0.15 170), oklch(65% 0.12 190));
    }
    .benefit-panel--leadership .panel-stripe {
      background: linear-gradient(90deg, oklch(70% 0.14 80), oklch(75% 0.12 55));
    }

    .benefit-panel .panel-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(5rem, 10vh, 9rem);
      font-weight: 800;
      color: oklch(100% 0 0 / 0.06);
      position: absolute;
      top: 0.5rem;
      right: 1rem;
      line-height: 1;
      pointer-events: none;
    }

    .benefit-panel .persona-tag {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: oklch(75% 0.03 0);
      margin-bottom: 0.4rem;
      opacity: 0;
      transition: opacity 0.3s var(--ease-out-expo);
    }

    .benefit-panel.expanded .persona-tag {
      opacity: 1;
    }

    .benefit-panel h3 {
      font-size: var(--step-2);
      font-weight: 800;
      color: oklch(95% 0.005 55);
      margin-bottom: var(--space-xs);
      opacity: 0;
      max-height: 0;
      overflow: hidden;
      transition: opacity 0.3s var(--ease-out-expo), max-height 0.3s var(--ease-out-expo), font-size 0.5s var(--ease-out-expo);
    }

    .benefit-panel.expanded h3 {
      font-size: var(--step-2);
      opacity: 1;
      max-height: 6rem;
    }

    /* Vertical label visible when collapsed */
    .benefit-panel .panel-vlabel {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(-90deg);
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: clamp(0.8rem, 1vw, 1.1rem);
      font-weight: 800;
      color: oklch(90% 0.005 55);
      white-space: nowrap;
      letter-spacing: 0.03em;
      opacity: 1;
      transition: opacity 0.3s var(--ease-out-expo);
      pointer-events: none;
      max-width: none;
    }

    .benefit-panel.expanded .panel-vlabel {
      opacity: 0;
    }

    .benefit-panel ul {
      list-style: none;
      padding: 0;
      display: grid;
      grid-template-rows: 0fr;
      opacity: 0;
      transition: grid-template-rows 0.5s var(--ease-out-expo), opacity 0.4s var(--ease-out-expo);
    }

    .benefit-panel ul > * {
      overflow: hidden;
    }

    .benefit-panel.expanded ul {
      grid-template-rows: 1fr;
      opacity: 1;
    }

    .benefit-panel ul li {
      padding: 0.5rem 0;
      font-size: clamp(1rem, 0.9rem + 0.3vw, 1.15rem);
      line-height: 1.5;
      color: oklch(82% 0.01 55);
      padding-left: 1.5rem;
      position: relative;
    }

    .benefit-panel ul li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.75rem;
      width: 7px;
      height: 7px;
      border-radius: 50%;
    }

    .benefit-panel--security ul li::before { background: oklch(70% 0.15 270); }
    .benefit-panel--platform ul li::before { background: oklch(65% 0.12 170); }
    .benefit-panel--leadership ul li::before { background: oklch(75% 0.12 80); }

    @media (max-width: 768px) {
      .benefits-panels {
        flex-direction: column;
        height: auto;
      }
      .benefit-panel {
        flex: none !important;
        min-height: 5rem;
      }
      .benefit-panel ul {
        grid-template-rows: 1fr !important;
        opacity: 1 !important;
      }
      .benefit-panel .persona-tag { opacity: 1 !important; }
    }

    /* ── CTA (Chapter 9) — Journey Path ─────────────── */
    .cta-journey {
      display: flex;
      align-items: stretch;
      gap: 0;
      margin: var(--space-m) 0;
      position: relative;
    }

    .cta-journey::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), oklch(55% 0.12 270), oklch(60% 0.1 240));
      transform: translateY(-50%);
      z-index: 0;
    }

    .journey-step {
      flex: 1;
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 0 var(--space-s);
    }

    .journey-milestone {
      width: clamp(3.5rem, 6vw, 5rem);
      height: clamp(3.5rem, 6vw, 5rem);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto var(--space-m);
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      color: white;
      position: relative;
      transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
    }

    .journey-milestone:hover {
      transform: scale(1.1);
    }

    .journey-step:nth-child(1) .journey-milestone {
      background: linear-gradient(135deg, oklch(50% 0.15 270), oklch(55% 0.12 290));
      box-shadow: 0 6px 24px oklch(50% 0.15 270 / 0.3);
    }

    .journey-step:nth-child(2) .journey-milestone {
      background: linear-gradient(135deg, oklch(50% 0.12 240), oklch(55% 0.15 260));
      box-shadow: 0 6px 24px oklch(50% 0.12 240 / 0.3);
    }

    .journey-step:nth-child(3) .journey-milestone {
      background: linear-gradient(135deg, oklch(50% 0.12 200), oklch(55% 0.1 220));
      box-shadow: 0 6px 24px oklch(50% 0.12 200 / 0.3);
    }

    .journey-arrow {
      position: absolute;
      top: 50%;
      right: -0.75rem;
      transform: translateY(-50%);
      width: 1.5rem;
      height: 1.5rem;
      z-index: 2;
      color: var(--accent);
    }

    .journey-step:last-child .journey-arrow {
      display: none;
    }

    .journey-step h3 {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-1);
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.5rem;
    }

    .journey-step p {
      font-size: 0.9375rem;
      color: var(--text-muted);
      max-width: 28ch;
      margin-inline: auto;
    }

    @media (max-width: 768px) {
      .cta-journey {
        flex-direction: column;
        gap: var(--space-m);
      }
      .cta-journey::before {
        width: 3px;
        height: 100%;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
      }
      .journey-arrow { display: none !important; }
    }

    .cta-footer {
      display: flex;
      align-items: center;
      gap: var(--space-m);
      margin-top: var(--space-l);
      flex-wrap: wrap;
    }

    .cta-footer svg { height: 2rem; }
    .cta-footer .hashicorp-logo { color: var(--text); }

    .cta-hostname {
      font-family: 'DM Sans', monospace;
      font-size: 0.875rem;
      color: oklch(55% 0.008 55);
      margin-top: var(--space-m);
    }

    .cta-hostname .typed {
      border-right: 2px solid var(--vault-gold);
      padding-right: 2px;
      animation: blink 1s step-end infinite;
    }

    @keyframes blink {
      50% { border-color: transparent; }
    }

    /* key-hint removed */

    /* ── Animation: Hero Signature Load Sequence ────── */
    .hero-logos {
      opacity: 0;
      transform: scale(0.8);
      transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
    }
    .hero-logos.show {
      opacity: 1;
      transform: scale(1);
    }
    .hero-logos svg:first-child {
      opacity: 0;
      transform: scale(0.8);
      transition: opacity 0.5s var(--ease-out-expo) 0.1s, transform 0.5s var(--ease-out-expo) 0.1s;
    }
    .hero-logos.show svg:first-child {
      opacity: 1;
      transform: scale(1);
    }
    .hero-logos .logo-divider {
      opacity: 0;
      transform: scaleY(0);
      transition: opacity 0.3s var(--ease-out-expo) 0.3s, transform 0.3s var(--ease-out-expo) 0.3s;
    }
    .hero-logos.show .logo-divider {
      opacity: 1;
      transform: scaleY(1);
    }
    .hero-logos svg:last-of-type {
      opacity: 0;
      transform: scale(0.8);
      transition: opacity 0.5s var(--ease-out-expo) 0.4s, transform 0.5s var(--ease-out-expo) 0.4s;
    }
    .hero-logos.show svg:last-of-type {
      opacity: 1;
      transform: scale(1);
    }
    .hero-subtitle {
      opacity: 0;
      transform: translateX(1.5rem);
    }
    .hero-subtitle.hero-sub-show {
      opacity: 1;
      transform: translateX(0);
      transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
    }
    .scroll-hint {
      opacity: 0;
    }
    .scroll-hint.hero-hint-show {
      opacity: 1;
      transition: opacity 0.6s var(--ease-out-expo);
    }

    /* ── Animation: Card Hover Effects ───────────────── */
    .shift-stat-block,
    .incident-card,
    .engine-card {
      transition: transform 0.3s var(--ease-out-quart), box-shadow 0.3s var(--ease-out-quart);
    }
    .shift-stat-block:hover,
    .incident-card:hover,
    .engine-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px oklch(0% 0 0 / 0.08);
    }

    /* ── Animation: Lifecycle Wheel Enhancements ───── */
    @keyframes pulseGlow {
      0%, 100% { filter: drop-shadow(0 0 0px currentColor); }
      50% { filter: drop-shadow(0 0 8px currentColor); }
    }
    .lifecycle-node.active {
      animation: pulseGlow 2s ease-in-out infinite;
    }

    @keyframes flowDash {
      to { stroke-dashoffset: -20; }
    }
    #arcs path {
      animation: flowDash 3s linear infinite;
    }

    /* Particle flow animation along connectors */
    @keyframes particleFlow {
      0% { offset-distance: 0%; opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { offset-distance: 100%; opacity: 0; }
    }

    /* ── Animation: Staggered List Item Reveals ────── */
    .engine-card li,
    .lifecycle-detail-panel li {
      opacity: 0;
      transform: translateX(-12px);
      transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    }
    .engine-card.visible li,
    .lifecycle-detail-panel.active li {
      opacity: 1;
      transform: translateX(0);
    }
    .engine-card li,
    .lifecycle-detail-panel li {
      transition-delay: calc(var(--li-i, 0) * 80ms);
    }

    /* ── Animation: Bridge Connector Line Draw ──────── */
    .bridge-connector svg line {
      stroke-dasharray: 180;
      stroke-dashoffset: 180;
      transition: stroke-dashoffset 0.8s var(--ease-out-expo);
    }
    .bridge-connector.visible svg line {
      stroke-dashoffset: 0;
    }
    .bridge-connector svg circle {
      opacity: 0;
      transform-origin: center;
      transform: scale(0);
      transition: opacity 0.4s var(--ease-out-expo) 0.8s, transform 0.4s var(--ease-out-expo) 0.8s;
    }
    .bridge-connector.visible svg circle {
      opacity: 1;
      transform: scale(1);
    }
    .bridge-connector svg circle:nth-child(3) {
      transition-delay: 0.6s;
    }
    .bridge-connector svg circle:nth-child(4) {
      transition-delay: 1s;
    }
    @keyframes bridgePulse {
      0%, 100% { filter: drop-shadow(0 0 0px var(--accent)); }
      50% { filter: drop-shadow(0 0 6px var(--accent)); }
    }
    .bridge-connector.visible svg circle:nth-child(3) {
      animation: bridgePulse 2s ease-in-out infinite 1.2s;
    }

    /* ── Animation: Timeline Activation ────────────── */
    .timeline-step .marker {
      transform: scale(1);
    }
    .timeline.visible .timeline-step .marker {
      animation: markerPulse 0.4s var(--ease-out-expo) forwards;
    }
    .timeline.visible .timeline-step:nth-child(1) .marker { animation-delay: 0s; }
    .timeline.visible .timeline-step:nth-child(2) .marker { animation-delay: 0.2s; }
    .timeline.visible .timeline-step:nth-child(3) .marker { animation-delay: 0.4s; }
    .timeline.visible .timeline-step:nth-child(4) .marker { animation-delay: 0.6s; }
    @keyframes markerPulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.6); }
      100% { transform: scale(1.3); }
    }

    /* ── Animation: Outcome Values Parallax ──────────── */
    .outcome-value {
      will-change: transform;
      transition: transform 0.1s linear;
    }

    /* ── Animation: Shield layer stagger ──────────────── */
    .shield-layer {
      opacity: 0;
      transform: translateX(2rem);
      transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo), box-shadow 0.5s var(--ease-out-expo);
    }
    .shield-layer.visible {
      opacity: 1;
      transform: translateX(0);
    }
    .shield-layer:nth-child(1) { transition-delay: 0s; }
    .shield-layer:nth-child(2) { transition-delay: 0.15s; }
    .shield-layer:nth-child(3) { transition-delay: 0.3s; }

    /* ── Animation: Benefit panel expand on click ─────── */

    /* ── Animation: Journey milestone pulse ───────────── */
    .journey-step.visible .journey-milestone {
      animation: milestonePop 0.5s var(--ease-out-expo) forwards;
    }
    @keyframes milestonePop {
      0% { transform: scale(0.6); opacity: 0; }
      60% { transform: scale(1.08); }
      100% { transform: scale(1); opacity: 1; }
    }

    /* ── Animation: prefers-reduced-motion overrides ── */
    @media (prefers-reduced-motion: reduce) {
      .hero-logos,
      .hero-logos svg,
      .hero-logos .logo-divider,
      .hero-subtitle,
      .scroll-hint {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
        animation: none !important;
      }
      .shift-stat-block,
      .incident-card,
      .engine-card,
      .benefit-panel,
      .shield-layer {
        transition: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
      .shift-stat-block:hover,
      .incident-card:hover,
      .engine-card:hover,
      .benefit-panel:hover,
      .shield-layer:hover {
        transform: none !important;
      }
      .benefit-panel ul {
        grid-template-rows: 1fr !important;
        opacity: 1 !important;
      }
      .benefit-panel .persona-tag {
        opacity: 1 !important;
      }
      .lifecycle-node.active { animation: none !important; }
      #arcs path { animation: none !important; }
      .engine-card li,
      .lifecycle-detail-panel li {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      .bridge-connector svg line,
      .bridge-connector svg circle {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
        stroke-dashoffset: 0 !important;
        animation: none !important;
      }
      .timeline.visible .timeline-step .marker { animation: none !important; }
      .chapter-nav .dot svg circle.progress { transition: none !important; }
      .slide-track { transition: none !important; }
      .journey-step.visible .journey-milestone { animation: none !important; opacity: 1 !important; }
    }
  </style>
</head>
<body>

<!-- Progress Bar -->
<div class="progress-bar" id="progressBar"></div>

<!-- Chapter Navigation (bottom) -->
