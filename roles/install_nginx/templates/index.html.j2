<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Certificate Lifecycle Management — HashiCorp Vault + Red Hat Ansible</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ── Reset ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design Tokens ────────────────────────────────── */
    :root {
      --bg:          oklch(97.5% 0.005 55);
      --bg-alt:      oklch(95% 0.008 55);
      --bg-warm:     oklch(96% 0.015 80);
      --bg-cool:     oklch(96.5% 0.008 240);
      --bg-light:    oklch(98.5% 0.003 55);
      --text:        oklch(18% 0.01 55);
      --text-muted:  oklch(45% 0.01 55);
      --text-faint:  oklch(65% 0.008 55);
      --vault-gold:  #FFD814;
      --vault-dark:  #1A1A2E;
      --redhat-red:  #EE0000;
      --accent:      oklch(55% 0.15 270);
      --border:      oklch(88% 0.008 55);

      --step-0: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --step-1: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
      --step-2: clamp(1.75rem, 1.4rem + 1.75vw, 2.5rem);
      --step-3: clamp(2.5rem, 1.8rem + 3.5vw, 4rem);
      --step-4: clamp(3.5rem, 2.2rem + 6.5vw, 6.5rem);
      --step-hero: clamp(3rem, 2rem + 5vw, 5.5rem);

      --space-xs:  clamp(0.5rem, 0.4rem + 0.5vw, 0.75rem);
      --space-s:   clamp(0.75rem, 0.6rem + 0.75vw, 1.25rem);
      --space-m:   clamp(1.5rem, 1rem + 2.5vw, 3rem);
      --space-l:   clamp(3rem, 2rem + 5vw, 6rem);
      --space-xl:  clamp(5rem, 3rem + 10vw, 10rem);

      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      --measure: 65ch;
    }

    /* ── Base ──────────────────────────────────────────── */
    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
      scroll-snap-type: y mandatory;
      overflow-y: scroll;
    }

    body {
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      font-size: var(--step-0);
      font-weight: 400;
      line-height: 1.65;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    h1, h2, h3, h4 {
      font-family: 'Outfit', system-ui, -apple-system, sans-serif;
      line-height: 1.1;
      letter-spacing: -0.02em;
    }

    p { max-width: var(--measure); }

    /* ── Progress Bar ─────────────────────────────────── */
    .progress-bar {
      position: fixed;
      top: 0;
      left: 0;
      height: 3px;
      background: var(--accent);
      z-index: 200;
      width: 0%;
      transition: width 0.15s linear;
      will-change: width;
    }

    /* ── Chapter Side Navigation ──────────────────────── */
    .chapter-nav {
      position: fixed;
      right: clamp(1rem, 2vw, 2.5rem);
      top: 50%;
      transform: translateY(-50%);
      z-index: 100;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      align-items: flex-end;
    }

    .chapter-nav a {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      color: var(--text-faint);
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      transition: color 0.3s var(--ease-out-expo);
    }

    .chapter-nav a .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--border);
      transition: background 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
      flex-shrink: 0;
    }

    .chapter-nav a .label {
      opacity: 0;
      transform: translateX(8px);
      transition: opacity 0.3s var(--ease-out-expo), transform 0.3s var(--ease-out-expo);
      white-space: nowrap;
      text-transform: uppercase;
    }

    .chapter-nav a:hover .label,
    .chapter-nav a.active .label {
      opacity: 1;
      transform: translateX(0);
    }

    .chapter-nav a:hover .dot { background: var(--text-muted); }
    .chapter-nav a.active .dot {
      background: var(--accent);
      transform: scale(1.4);
    }
    .chapter-nav a.active { color: var(--text); }

    @media (max-width: 768px) {
      .chapter-nav { display: none; }
    }

    /* ── Slide (full-viewport section) ────────────────── */
    .slide {
      min-height: 100vh;
      scroll-snap-align: start;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: var(--space-l) 0;
      position: relative;
      overflow: hidden;
    }

    .wrap {
      width: min(90%, 72rem);
      margin-inline: auto;
      padding-inline: var(--space-s);
    }

    /* ── Reveal Animations ────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(2rem);
      transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }
    .reveal-delay-5 { transition-delay: 0.5s; }
    .reveal-delay-6 { transition-delay: 0.6s; }
    .reveal-delay-7 { transition-delay: 0.7s; }
    .reveal-delay-8 { transition-delay: 0.8s; }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
      html { scroll-snap-type: none; scroll-behavior: auto; }
      .hero-word { opacity: 1 !important; transform: none !important; }
      .scroll-hint { animation: none !important; }
      .counter { transition: none !important; }
    }

    /* ── Slide Backgrounds ────────────────────────────── */
    .slide--hero { background: var(--bg); }
    .slide--risk { background: var(--bg-warm); }
    .slide--shift { background: var(--vault-dark); color: #f0ece4; }
    .slide--shift .text-muted { color: oklch(75% 0.008 55); }
    .slide--together { background: var(--bg); }
    .slide--lifecycle { background: var(--bg-alt); }
    .slide--resilience { background: var(--bg-cool); }
    .slide--outcomes { background: var(--bg); }
    .slide--benefits { background: var(--bg-warm); }
    .slide--cta { background: var(--vault-dark); color: #f0ece4; }

    /* ── Hero ──────────────────────────────────────────── */
    .hero-headline {
      font-size: var(--step-hero);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: var(--space-m);
    }

    .hero-word {
      display: inline-block;
      opacity: 0;
      transform: translateY(1.5rem);
      transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
    }

    .hero-word.show {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-logos {
      display: flex;
      align-items: center;
      gap: var(--space-m);
      margin-bottom: var(--space-m);
    }

    .hero-logos svg { height: clamp(2rem, 3vw, 3rem); }
    .hero-logos .hashicorp-logo { color: var(--text); }
    .hero-logos .logo-divider {
      width: 1px;
      height: 2rem;
      background: var(--border);
    }

    .hero-subtitle {
      font-size: var(--step-1);
      color: var(--text-muted);
      margin-bottom: var(--space-l);
    }

    .scroll-hint {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.875rem;
      color: var(--text-faint);
      font-family: 'Outfit', system-ui, sans-serif;
      font-weight: 600;
      letter-spacing: 0.03em;
    }

    .scroll-hint .arrow {
      display: inline-block;
      animation: bounce-down 2s var(--ease-out-expo) infinite;
    }

    @keyframes bounce-down {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }

    /* ── Section Headers ──────────────────────────────── */
    .section-label {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: var(--space-s);
    }

    .slide--shift .section-label,
    .slide--cta .section-label { color: var(--vault-gold); }

    .section-title {
      font-size: var(--step-3);
      font-weight: 800;
      margin-bottom: var(--space-m);
      max-width: 20ch;
    }

    /* ── Risk Section ─────────────────────────────────── */
    .incident-block {
      background: var(--bg-light);
      border-left: 4px solid var(--redhat-red);
      padding: var(--space-m);
      margin-bottom: var(--space-m);
      border-radius: 0 0.5rem 0.5rem 0;
    }

    .incident-block blockquote {
      font-size: var(--step-0);
      line-height: 1.7;
      color: var(--text);
      font-style: italic;
      max-width: var(--measure);
    }

    .incident-source {
      font-size: 0.8125rem;
      color: var(--text-muted);
      font-weight: 600;
      margin-top: var(--space-s);
      font-style: normal;
    }

    .incident-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
      gap: var(--space-s);
      margin-bottom: var(--space-m);
    }

    .incident-card {
      background: var(--bg-light);
      padding: var(--space-s) var(--space-m);
      border-radius: 0.5rem;
      border: 1px solid var(--border);
    }

    .incident-card strong {
      display: block;
      font-family: 'Outfit', system-ui, sans-serif;
      font-weight: 700;
      font-size: 0.9375rem;
      margin-bottom: 0.25rem;
    }

    .incident-card span {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .risk-stat {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
    }

    .risk-stat .counter-value { color: var(--redhat-red); }

    .risk-stat-source {
      font-size: 0.8125rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ── 47-Day Shift Section ─────────────────────────── */
    .shift-lead {
      font-size: var(--step-1);
      color: #f0ece4;
      max-width: var(--measure);
      margin-bottom: var(--space-m);
    }

    .timeline {
      display: flex;
      align-items: stretch;
      gap: 0;
      margin: var(--space-m) 0;
      position: relative;
    }

    .timeline::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 2px;
      background: oklch(40% 0.01 55);
    }

    .timeline-step {
      flex: 1;
      text-align: center;
      position: relative;
      padding: 0 var(--space-xs);
    }

    .timeline-step .marker {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: oklch(50% 0.01 55);
      margin: 0 auto var(--space-xs);
      position: relative;
      z-index: 2;
      transition: background 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo);
    }

    .timeline-step.active .marker {
      background: var(--vault-gold);
      transform: scale(1.3);
    }

    .timeline-step.future .marker { background: oklch(55% 0.12 270); }

    .timeline-days {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      color: #f0ece4;
    }

    .timeline-date {
      font-size: 0.8125rem;
      color: oklch(60% 0.008 55);
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .shift-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
      gap: var(--space-m);
      margin: var(--space-m) 0;
    }

    .shift-stat-block {
      padding: var(--space-m);
      background: oklch(15% 0.01 260);
      border-radius: 0.75rem;
      border: 1px solid oklch(25% 0.01 260);
    }

    .shift-stat-block .big-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-3);
      font-weight: 800;
      color: var(--vault-gold);
    }

    .shift-stat-block p {
      color: oklch(70% 0.008 55);
      font-size: 0.9375rem;
      margin-top: 0.5rem;
    }

    .shift-insight {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-1);
      font-weight: 700;
      color: oklch(80% 0.008 55);
      margin: var(--space-s) 0;
      max-width: var(--measure);
    }

    .shift-source {
      font-size: 0.75rem;
      color: oklch(50% 0.008 55);
      margin-top: var(--space-m);
    }

    /* ── Better Together ──────────────────────────────── */
    .together-grid {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: var(--space-m);
      align-items: center;
      margin-top: var(--space-m);
    }

    @media (max-width: 768px) {
      .together-grid {
        grid-template-columns: 1fr;
      }
      .bridge-connector { display: none !important; }
    }

    .engine-card {
      padding: var(--space-m);
      border-radius: 1rem;
      border: 1px solid var(--border);
      background: var(--bg-light);
    }

    .engine-card .engine-logo {
      height: 2.5rem;
      margin-bottom: var(--space-s);
    }

    .engine-card .engine-role {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.8125rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }

    .engine-card h3 {
      font-size: var(--step-2);
      font-weight: 800;
      margin-bottom: var(--space-s);
    }

    .engine-card ul {
      list-style: none;
      padding: 0;
    }

    .engine-card ul li {
      padding: 0.4rem 0;
      font-size: 0.9375rem;
      color: var(--text-muted);
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .engine-card ul li::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 0.5em;
    }

    .engine-card.vault ul li::before { background: var(--vault-gold); }
    .engine-card.ansible ul li::before { background: var(--redhat-red); }

    .bridge-connector {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .bridge-connector svg {
      width: clamp(3rem, 6vw, 6rem);
      color: var(--accent);
    }

    .bridge-connector span {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-faint);
      writing-mode: vertical-lr;
      text-orientation: mixed;
    }

    /* ── Lifecycle (Chapter 5) ────────────────────────── */
    .lifecycle-track {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-s);
      margin-top: var(--space-m);
    }

    @media (max-width: 900px) {
      .lifecycle-track {
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
      }
    }

    .lifecycle-step {
      padding: var(--space-m) var(--space-s);
      border-radius: 0.75rem;
      border: 1px solid var(--border);
      background: var(--bg-light);
      text-align: center;
      position: relative;
    }

    .lifecycle-step .step-number {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-3);
      font-weight: 800;
      color: var(--accent);
      opacity: 0.25;
      line-height: 1;
      margin-bottom: var(--space-xs);
    }

    .lifecycle-step h3 {
      font-size: var(--step-1);
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .lifecycle-step p {
      font-size: 0.875rem;
      color: var(--text-muted);
      max-width: none;
    }

    /* ── Resilience (Chapter 6) ───────────────────────── */
    .resilience-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
      gap: var(--space-m);
      margin-top: var(--space-m);
    }

    .resilience-card {
      padding: var(--space-m);
      border-radius: 0.75rem;
      background: var(--bg-light);
      border: 1px solid var(--border);
    }

    .resilience-card h3 {
      font-size: var(--step-1);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .resilience-card p {
      font-size: 0.9375rem;
      color: var(--text-muted);
    }

    .resilience-motto {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-2);
      font-weight: 800;
      margin-top: var(--space-m);
      color: var(--accent);
    }

    /* ── Outcomes (Chapter 7) ─────────────────────────── */
    .outcomes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
      gap: var(--space-m);
      margin-top: var(--space-m);
    }

    .outcome-item {
      text-align: left;
    }

    .outcome-item .outcome-value {
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: var(--step-3);
      font-weight: 800;
      line-height: 1;
      margin-bottom: 0.5rem;
      color: var(--text);
    }

    .outcome-item .outcome-label {
      font-size: 0.9375rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ── Who Benefits (Chapter 8) ─────────────────────── */
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
      gap: var(--space-m);
      margin-top: var(--space-m);
    }

    .benefit-card {
      padding: var(--space-m);
      border-radius: 0.75rem;
      position: relative;
      overflow: hidden;
    }

    .benefit-card--security {
      background: oklch(96% 0.015 270);
      border: 1px solid oklch(90% 0.02 270);
    }

    .benefit-card--platform {
      background: oklch(96% 0.015 160);
      border: 1px solid oklch(90% 0.02 160);
    }

    .benefit-card--leadership {
      background: oklch(96% 0.015 55);
      border: 1px solid oklch(90% 0.02 55);
    }

    .benefit-card h3 {
      font-size: var(--step-1);
      font-weight: 700;
      margin-bottom: var(--space-xs);
    }

    .benefit-card ul {
      list-style: none;
      padding: 0;
    }

    .benefit-card ul li {
      padding: 0.35rem 0;
      font-size: 0.9375rem;
      color: var(--text-muted);
      padding-left: 1rem;
      position: relative;
    }

    .benefit-card ul li::before {
      content: '\2022';
      position: absolute;
      left: 0;
      color: var(--accent);
      font-weight: 700;
    }

    /* ── CTA (Chapter 9) ──────────────────────────────── */
    .cta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
      gap: var(--space-m);
      margin: var(--space-m) 0;
    }

    .cta-card {
      padding: var(--space-m);
      border-radius: 0.75rem;
      background: oklch(15% 0.01 260);
      border: 1px solid oklch(25% 0.01 260);
    }

    .cta-card h3 {
      font-size: var(--step-1);
      font-weight: 700;
      color: #f0ece4;
      margin-bottom: 0.5rem;
    }

    .cta-card p {
      font-size: 0.9375rem;
      color: oklch(65% 0.008 55);
    }

    .cta-footer {
      display: flex;
      align-items: center;
      gap: var(--space-m);
      margin-top: var(--space-l);
      flex-wrap: wrap;
    }

    .cta-footer svg { height: 2rem; }
    .cta-footer .hashicorp-logo { color: #f0ece4; }

    .cta-hostname {
      font-family: 'DM Sans', monospace;
      font-size: 0.875rem;
      color: oklch(55% 0.008 55);
      margin-top: var(--space-m);
    }

    .cta-hostname .typed {
      border-right: 2px solid var(--vault-gold);
      padding-right: 2px;
      animation: blink 1s step-end infinite;
    }

    @keyframes blink {
      50% { border-color: transparent; }
    }

    /* ── Keyboard Hint ────────────────────────────────── */
    .key-hint {
      position: fixed;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      font-family: 'Outfit', system-ui, sans-serif;
      font-size: 0.75rem;
      color: var(--text-faint);
      background: var(--bg-light);
      border: 1px solid var(--border);
      padding: 0.35rem 1rem;
      border-radius: 2rem;
      z-index: 100;
      opacity: 0.7;
      transition: opacity 0.3s;
      pointer-events: none;
    }

    .key-hint kbd {
      display: inline-block;
